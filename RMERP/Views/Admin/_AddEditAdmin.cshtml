@model RMERP.DAL.Models.AdminUsers
@{
    ViewBag.Title = Model.AdmId > 0 ? "Edit Admin Users" : "Add Admin Users";
}
@using RMERP.Helpers

<div id="add_user" class="modal custom-modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog">
        <button type="button" class="close" data-dismiss="modal">&times;</button>
        <div class="modal-content modal-lg">
            <div class="modal-header">
                <h4 class="modal-title"> @ViewBag.Title</h4>
            </div>
            <div class="modal-body">
                <form class="m-b-30" id="frmAddEdit">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="row">
                        <input type="hidden" asp-for="AdmId" />
                        <div class="col-md-12">
                            <div class="form-group form-focus select-focus">
                                <label class="control-label">Firm</label>
                                <select asp-for="FrmId" class="select form-control floating"
                                        asp-items="@(new SelectList(ViewBag.firmList,"FrmId", "FrmName"))"></select>

                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group form-focus">
                                <label asp-for="AdmFirstName" class="control-label"></label>
                                <input asp-for="AdmFirstName" class="form-control floating" />
                                <span asp-validation-for="AdmFirstName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group form-focus">
                                <label asp-for="AdmMiddleName" class="control-label"></label>
                                <input asp-for="AdmMiddleName" class="form-control floating" />
                                <span asp-validation-for="AdmMiddleName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group form-focus">
                                <label asp-for="AdmLastName" class="control-label"></label>
                                <input asp-for="AdmLastName" class="form-control floating" />
                                <span asp-validation-for="AdmLastName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group form-focus">
                                <label asp-for="AdmMobile" class="control-label"></label>
                                <input asp-for="AdmMobile" class="form-control floating" />
                                <span asp-validation-for="AdmMobile" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group form-focus">
                                <label asp-for="AdmEmailId" class="control-label"></label>
                                <input asp-for="AdmEmailId" class="form-control floating" />
                                <span asp-validation-for="AdmEmailId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group form-focus">
                                <label asp-for="AdmPassword" class="control-label"></label>
                                <input asp-for="AdmPassword" class="form-control floating" />
                                <span asp-validation-for="AdmPassword" class="text-danger"></span>
                            </div>
                        </div>

                        @*@Html.Image()*@
                        @*<img src="~/RMERP_Data/ClientsLogo/user.jpg" />*@

                        @*<div class="col-md-6">
            <div class="form-group">
                <label asp-for="AdmConfirmPassword" class="control-label"></label>
                <input asp-for="AdmConfirmPassword" class="form-control" />
                <span asp-validation-for="AdmConfirmPassword" class="text-danger"></span>
            </div>
        </div>*@


                    </div>
                    <div class="m-t-20 text-center">
                        <button class="btn btn-primary" onclick="onSaveClick()">Submit Admin User</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript" src="~/assets/js/appFloat.js"></script>
