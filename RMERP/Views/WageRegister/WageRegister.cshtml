@model List<RMERP.DAL.ViewModel.ClientWageRegisterVM>
@using RMERP.DAL.Models
@using RMERP.Helpers
@using RMERP.DAL.ViewModel

@{
    ViewData["Title"] = "WageRegister";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
    Allowances allowances1 = new Allowances();
}

@section scripts{
    <script>
        $(document).ready(function () {
            $("#myTab a:first").tab('show');
        });
    </script>
}

<style>
    .gainsboro {
        background-color: #DCDCDC;
    }
    .lightgray {
        background-color: #D3D3D3;
    }
    .silver {
        background-color: #C0C0C0;
    }
    .darkgray {
        background-color: #A9A9A9;
    }
    .gray {
        background-color: #a29e9e;
    }
    .dimgray {
        background-color: #7b7878;
    }
    .fa-check-circle {
        color: green;
    }
    .fa-times-circle {
        color: red;
    }
    .fa-info-circle {
        color: #ff9b44;
    }

    a.myClass {
        color: #f5f5f5;
    }
        a.myClass:hover,
        a.myClass:active,
        a.myClass:focus {
            text-decoration: none;
            color: #C0C0C0;
            outline: none;
        }
</style>

@{
    WageProcessVM wage = Model[0].wageProcessVM;
    int DaysInMonth = DateTime.DaysInMonth(wage.WAG_Month.Year, wage.WAG_Month.Month);
}

<h2>@wage.WAG_Full_Month() @*<small>Total Days: @DaysInMonth</small>*@</h2>

<ul class="nav nav-tabs" id="myTab">
    @foreach (var client in Model.Select(m => new { m.client, m.wageProcessClientVM, m.wageProcessVM.Attendance }).Distinct())
    {
        <li>
            <a data-toggle="tab" href="#@client.client.CLI_Id">
                @*fa-question-circle*@
                @{int attCount = client.Attendance.Where(m => m.CLI_Id.Equals(client.client.CLI_Id)).Count();}
                <i class="fa fa-@( client.wageProcessClientVM != null ? "check-circle" :attCount <=0 ? "times-circle":"info-circle" )"></i>
                @client.client.CLI_Name
            </a>
        </li>
    }
</ul>

<div class="tab-content">
    @foreach (var item in Model)
    {
        <div id="@item.client.CLI_Id" class="tabcontent tab-pane fade">
            <div class="well well-sm"> <h3><u>@item.client.CLI_Name</u></h3></div>
            <hr />
            @{
                var distinceDesignations = item.wageRegisterVMs.Select(q => new { q.designation.DES_Id, q.designation.DES_Title }).Distinct();
            }
            @foreach (var dd in distinceDesignations)
            {                
                List<WageRegisterVM> wageRegisters = item.wageRegisterVMs.Where(r => r.designation.DES_Id.Equals(dd.DES_Id)).ToList();
                <h3>@dd.DES_Title</h3>
                <div class="table-responsive">
                    <table class="table table-border">
                        <thead style="font-weight:500">
                            <tr>
                                <td class="gainsboro">ID</td>
                                <td class="gainsboro">Name</td>
                                <td class="gainsboro">M/F</td>
                                <td class="gainsboro">Date Of Joining</td>
                                <td class="lightgray">Total Days</td>
                                <td class="lightgray">Pay Days</td>
                                <td class="lightgray">Basic</td>
                                <td class="lightgray">Basic Calculated</td>
                                <td class="lightgray">DA</td>
                                <td class="lightgray">DA Calculated</td>
                                <td class="lightgray">HRA</td>
                                <td class="lightgray">HRA Calculated</td>
                                @foreach (var all in wageRegisters[0].allowanceVMs)
                                {
                                    <td class="lightgray">@all.allowanceVM.ALL_Alias</td>
                                    <td class="lightgray">@all.allowanceVM.ALL_Alias Calculated</td>
                                }
                                <td class="lightgray" rowspan="2">OT Hours</td>
                                <td class="lightgray">OT Payment times</td>
                                <td class="lightgray">OT Amount</td>
                                <td class="lightgray">Working Hrs In Day</td>
                                <td class="lightgray">Gross Total</td>
                                <td class="silver" rowspan="2">PF</td>
                                <td class="silver">PF Calculated</td>
                                <td class="silver">ESIC</td>
                                <td class="silver">ESIC Formula</td>
                                <td class="silver">ESIC Calculated</td>
                                <td class="silver">Advance Installment</td>
                                <td class="gray">Final Amount</td>
                                @if (item.wageProcessClientVM != null && item.wageProcessVM.WageStatus == false)
                                {
                                    <td class="dimgray"></td>
                                }
                            </tr>
                        </thead>
                        <tbody>

                            @foreach (var employee in wageRegisters)
                            {                                
                            <tr>
                                <td class="gainsboro">@employee.employeeVM.EMP_Id.ToString("D5")</td>
                                <td class="gainsboro">@employee.employeeVM.EMP_FirstName @employee.employeeVM.EMP_MiddleName @employee.employeeVM.EMP_SurName</td>
                                <td class="gainsboro">@(employee.employeeVM.EMP_Gender == true ? "M" : "F")</td>
                                <td class="gainsboro">@DateHelper.getDateWithFormat(employee.employeeVM.EMP_DateOfJoining)</td>
                                <td class="lightgray">@employee.WAR_TotalWorkingDays</td>
                                <td class="lightgray">@employee.WAR_TotalPaybleDays</td>
                                <td class="lightgray">@(String.Format("{0:0.##}", employee.WAR_Basic))</td>
                                <td class="lightgray">@(String.Format("{0:0.##}", employee.WAR_Basic_Calculated))</td>
                                <td class="lightgray">@(String.Format("{0:0.##}", employee.WAR_DA))</td>
                                <td class="lightgray">@(String.Format("{0:0.##}", employee.WAR_DA_Calculated))</td>
                                <td class="lightgray">@employee.WAR_HRA_PER</td>
                                <td class="lightgray">@(String.Format("{0:0.##}", employee.WAR_HRA_Calculated))</td>
                                @{
                                    foreach (var all in employee.allowanceVMs)
                                    {
                                        <td class="lightgray">@(String.Format("{0:0.##}", all.WAA_Amount))</td>
                                        <td class="lightgray">@(String.Format("{0:0.##}", all.WAA_Amount_Calculated))</td>
                                    }
                                }
                                <td class="lightgray">@employee.WAR_ExtraWorkingHours (@(employee.WAR_OverTime_Formula != null ? employee.WAR_OverTime_Formula : "-"))</td>
                                <td class="lightgray">@(employee.WAR_OverTime_Payment)</td>
                                <td class="lightgray">@(String.Format("{0:0.##}", employee.WAR_OverTime_Calculated))</td>
                                <td class="lightgray">@(employee.WAR_WorkingHrs_In_Day)</td>
                                <td class="lightgray">@Math.Round(employee.WAR_GrossTotal, 2)</td>
                                <td class="silver">@Convert.ToDouble(employee.WAR_PF)%  (@(employee.WAR_PF_Formula != null ? employee.WAR_PF_Formula : "-"))</td>
                                <td class="silver">@(String.Format("{0:0.##}", employee.WAR_PF_Calculated))</td>
                                <td class="silver">@Convert.ToDouble(employee.WAR_ESIC)%</td>
                                <td class="silver">@employee.WAR_ESIC_Formula</td>
                                <td class="silver">@(String.Format("{0:0.##}", employee.WAR_ESIC_Calculated))</td>
                                <td class="silver">@employee.WAR_Advance_Amount</td>
                                <td class="gray">@(String.Format("{0:0.##}", employee.WAR_FinalTotal))</td>

                                @if (item.wageProcessClientVM != null && item.wageProcessVM.WageStatus == false)
                                {
                                    <td class="dimgray my-class">@Html.ActionLink("Edit", "EditWageRegister", "WageRegister", new { WAR_Id = employee.WAR_Id }, new { @class = "myClass" })</td>
                                }

                            </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            
            @if (item.wageProcessVM.WageStatus == false)
            {
                <div class="container">
                    @using (Html.BeginForm("SaveWageRegister", "WageRegister"))
                    {
                        <input type="hidden" name="item_CLI_Id" value="@item.client.CLI_Id" />
                        <input type="hidden" name="WAG_Id" value="@wage.WAG_Id" />
                        if (item.wageProcessClientVM != null)
                        {
                            <div class="alert alert-success" style="position: absolute;">
                                <h2>Web Register is finalized on  @DateHelper.getDateWithFormat(item.wageProcessClientVM.WPC_SavedOn)</h2> <br />
                                <input type="submit" value="Reset" formaction="ResetWageRegister" onclick="return confirm('Are you sure you want to reset?');" class="btn btn-success pull-right" />
                            </div>
                        }
                        else if (item.wageProcessVM.Attendance.Where(m=>m.CLI_Id.Equals(item.client.CLI_Id)).Count()<=0)
                        {
                            <div class="alert alert-danger" style="position: absolute;">
                                <h2>Attandance is pending </h2><br />
                            </div>
                        }
                        else 
                        {
                            <div class="alert alert-warning" style="position: absolute;">
                                <h2>Web Register is ready to finalize</h2> <br />
                                <input type="submit" value="Save" formaction="SaveWageRegister" onclick="return confirm('Are you sure you want to save?');" class="btn btn-warning pull-right" />
                            </div>
                        }
                    }
                </div>
            }
        </div>

     }

</div>
