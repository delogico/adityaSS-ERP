@model RMERP.DAL.ViewModel.ClientWageRegisterVM
@using RMERP.DAL.Models
@using RMERP.Helpers
@using RMERP.DAL.ViewModel
@using RMERP.DAL.Helpers
@{
    ViewData["Title"] = "WageRegister";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
    Allowance allowances1 = new Allowance();

    WageProcessVM wage = Model.wageProcessVM;
    int DaysInMonth = DateTime.DaysInMonth(Model.wageProcessVM.WAG_Month.Year, Model.wageProcessVM.WAG_Month.Month);
    bool IsNullCR = false;

    int DV_Update = 1;
}
@section Breadcrumbs {
    <li class="breadcrumb-item">@Html.ActionLink("Wage Process", "Index", "WageProcess", new { FRM_Id = Model.wageProcessVM.FRM_Id })</li>
    <li class="breadcrumb-item">@Html.ActionLink("Wage Process Clients Status", "WageProcessClients", "WageRegister", new { WAG_Id = Model.wageProcessVM.WAG_Id, FRM_Id = Model.wageProcessVM.FRM_Id })</li>
    <li class="breadcrumb-item">Wage Register</li>
}
<style type="text/css">
    .gainsboro {
        background-color: #DCDCDC;
    }

    .lightgray {
        background-color: #D3D3D3;
    }

    .silver {
        background-color: #C0C0C0;
    }

    .darkgray {
        background-color: #A9A9A9;
    }

    .gray {
        background-color: #a29e9e;
    }

    .dimgray {
        background-color: #7b7878;
    }

    .fa-check-circle {
        color: green;
    }

    .fa-times-circle {
        color: red;
    }

    .fa-info-circle {
        color: #5e81f3;
    }

    a.myClass {
        color: #f5f5f5;
    }

        a.myClass:hover,
        a.myClass:active,
        a.myClass:focus {
            text-decoration: none;
            color: #C0C0C0;
            outline: none;
        }
</style>
<div class="content container-fluid">
    <div class="row">
        <div class="col-sm-6">
            <h3 class="page-title">
                @ViewData["Title"] (@Model.wageProcessVM.FRM_Title/@Model.wageProcessVM.WAG_Full_Month() )
            </h3>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="row">
                <div class="col-sm-12 text-center">
                    <h3 class="well">@Model.client.CLI_Name</h3>
                </div>
            </div>
            @{
                var distinceDesignations = Model.wageRegisterVMs.Select(q => new { q.designation.DES_Id, q.designation.DES_Title, q.designation.DES_Exclude_LWF }).Distinct();
            }

            @foreach (var dd in distinceDesignations)
            {
                int srNo = 0;
                List<WageRegisterVM> wageRegisters = Model.wageRegisterVMs.Where(r => r.designation.DES_Id.Equals(dd.DES_Id)).OrderBy(m => m.EMP_Id).ToList();
                ClientRequirementVM clientRequirement = wageRegisters.Select(m => m.clientRequirementVM).Where(m => m.CLI_Id.Equals(Model.client.CLI_Id) && m.DES_Id.Equals(dd.DES_Id)).FirstOrDefault();

                <div class="row">
                    <div class="col-sm-6">
                        <h3>@dd.DES_Title</h3>
                    </div>
                    @if (clientRequirement != null && Model.wageProcessClientVM == null)
                    {
                        <div class="col-sm-6 text-right">
                            <a href="javascript:void(0);" onclick="ShowUpdatePan(@DV_Update)" class="btn btn-info"><i class="fa fa-arrow-circle-down"></i> Updates</a>
                        </div>
                    }
                    @if (clientRequirement == null)
                    {
                        IsNullCR = true;
                        <div class="col-sm-3">
                        </div>
                        <div class="col-sm-4">
                            <div class="alert alert-danger text-right" role="alert">
                                No Requirement Found For This Wage Month!
                            </div>
                        </div>
                    }
                </div>

                @if (clientRequirement != null)
                {
                    <div class="row mt-2">
                        <div class="col-sm-12 text-center">
                            <div id="DV_Updates_@DV_Update" style="display:none;">
                                @if (clientRequirement.CRI_CanteenFacility)
                                {
                                    if (Model.wageProcessClientVM == null && Model.wageProcessVM.WageStatus == false)
                                    {
                                        @Html.ActionLink("Update canteen Amount", "UpdateCanteenAmount", "Canteen", new { CRI_Id = clientRequirement.CRI_Id, WAG_Id = wage.WAG_Id, FRM_Id = wage.FRM_Id }, new { @class = "btn btn-sm btn-primary rounded m-b-5" })
                                        ;
                                    }
                                }
                                &nbsp;
                                @if (clientRequirement.CRI_OutStation_Allowance)
                                {
                                    if (Model.wageProcessClientVM == null && !Model.wageProcessVM.WageStatus)
                                    {
                                        @Html.ActionLink("Update Outstation Hours", "UpdateOutstationHours", "Outstation", new { CRI_Id = clientRequirement.CRI_Id, WAG_Id = wage.WAG_Id, FRM_Id = wage.FRM_Id }, new { @class = "btn btn-sm btn-primary rounded m-b-5" })
                                        ;
                                    }
                                }
                                &nbsp;
                                @if (clientRequirement.CRI_Performance_Allowance)
                                {
                                    if (Model.wageProcessClientVM == null && !Model.wageProcessVM.WageStatus)
                                    {
                                        @Html.ActionLink("Update Performance Amount", "NewUpdatePerformanceAmount", "Performance", new { CRI_Id = clientRequirement.CRI_Id, WAG_Id = wage.WAG_Id, FRM_Id = wage.FRM_Id }, new { @class = "btn btn-sm btn-primary rounded m-b-5" })
                                        ;
                                    }
                                }
                                &nbsp;
                                @if (clientRequirement.CRI_Allowance_1)
                                {
                                    @if (Model.wageProcessClientVM == null && !Model.wageProcessVM.WageStatus)
                                    {
                                        @Html.ActionLink("Update " + clientRequirement.CRI_Allowance_Name_1 + " Amount", "UpdateAllowanceAmount_1", "Allowances", new { CRI_Id = clientRequirement.CRI_Id, WAG_Id = wage.WAG_Id, FRM_Id = wage.FRM_Id }, new { @class = "btn btn-sm btn-primary rounded m-b-5" })
                                        ;
                                    }
                                }
                                &nbsp;
                                @if (clientRequirement.CRI_Allowance_2)
