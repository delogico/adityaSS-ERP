                                    {
                                        @Html.ActionLink("Update " + clientRequirement.CRI_Allowance_Name_6 + " Amount", "UpdateAllowanceAmount_6", "Allowances", new { CRI_Id = clientRequirement.CRI_Id, WAG_Id = wage.WAG_Id, FRM_Id = wage.FRM_Id }, new { @class = "btn btn-sm btn-primary rounded m-b-5" })
                                        ;
                                    }
                                }
                                &nbsp;
                                @if (clientRequirement.CRI_Allowance_7)
                                {
