                                @Html.LabelFor(m => m.wageRegisterVM.WAR_PF_Calculated, new { @class = "control-label" })
                                @Html.EditorFor(m => m.wageRegisterVM.WAR_PF_Calculated, new { htmlAttributes = new { @class = "form-control", @readonly = true } })
                                @Html.ValidationMessageFor(m => m.wageRegisterVM.WAR_PF_Calculated, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.wageRegisterVM.WAR_ESIC, new { @class = "control-label" })
                                @Html.EditorFor(m => m.wageRegisterVM.WAR_ESIC, new { htmlAttributes = new { @class = "form-control", onfocusout = "calculateTotal()" } })
                                @Html.ValidationMessageFor(m => m.wageRegisterVM.WAR_ESIC, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.wageRegisterVM.WAR_ESIC_Calculated, new { @class = "control-label" })
                                @Html.EditorFor(m => m.wageRegisterVM.WAR_ESIC_Calculated, new { htmlAttributes = new { @class = "form-control", @readonly = true } })
                                @Html.ValidationMessageFor(m => m.wageRegisterVM.WAR_ESIC_Calculated, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        @{
                            for (var i = 0; i < Model.wage_Register_Allowances.Count(); i++)
                            {
                                <div class="col-md-12">
                                    @Html.Label(Model.wage_Register_Allowances[i].CRA_.ALL_.ALL_Title)
                                    @Html.RadioButtonFor(m => Model.wage_Register_Allowances[i].CRA_.CRA_DayswiseOrFull, true, new { @id = "CRA_Dayswise[" + @i + "]", @checked = "checked", @style = "margin: 0px 0 0" ,onclick = "calculateTotal()" }) Dayswise Calculation
                                    @Html.RadioButtonFor(m => Model.wage_Register_Allowances[i].CRA_.CRA_DayswiseOrFull, false, new { @id = "CRA_Full[" + @i + "]", @style = "margin: 0px 0 0", onclick = "calculateTotal()" })  Full Amount
                                    <div class="form-group">
                                        <div class="col-md-6">
                                            @Html.EditorFor(m => Model.wage_Register_Allowances[i].WAA_Amount, new { htmlAttributes = new { @class = "form-control", onfocusout = "calculateTotal()" } })
                                            @Html.ValidationMessageFor(m => Model.wage_Register_Allowances[i].WAA_Amount, "", new { @class = "text-danger" })
