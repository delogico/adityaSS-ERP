                                @Html.EditorFor(m => m.wageRegisterVM.WAR_FinalTotal, new { htmlAttributes = new { @class = "form-control", @readonly = true } })
                                @Html.ValidationMessageFor(m => m.wageRegisterVM.WAR_FinalTotal, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>

                    <div class="m-t-20 text-center">
                        <input type="submit" name="Submit Wage Register" id="btnSubmit" class="btn btn-primary" />
                    </div>
                }

            </div>
        </div>
    </div>
</div>

