@model RMERP.DAL.ViewModel.UploadExcelViewModel

@{
    ViewData["Title"] = "Upload Excel";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}
@section Breadcrumbs{
    <li class="breadcrumb-item">@Html.ActionLink("Wage Process", "Index", "WageProcess", new { FRM_Id = Model.wageProcessVM.FRM_Id })</li>
    <li class="breadcrumb-item">@Html.ActionLink("Wage Attendance", "WageAttendanceList", "Attendance", new { WAG_Id = Model.wageProcessVM.WAG_Id })</li>
    <li class="breadcrumb-item">Upload Attendance Excel</li>
}
@section scripts{
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>
}
<div class="modal-dialog modelLeftSide">
    <button type="button" class="close" data-dismiss="modal">&times;</button>
    <div class="modal-content modal-lg" style="width: 250%">
        <div class="modal-header">
            <h4 class="modal-title">Upload Attendance</h4>
        </div>
        <div class="modal-body">
            @using (Html.BeginForm("VerifyTemplate", "Attendance", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.HiddenFor(m => m.wageProcessVM.WAG_Id)
                @Html.HiddenFor(m => m.wageProcessVM.FRM_Id)
                @Html.HiddenFor(m => m.client.CLI_Id)
                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                <div class="row">
                    <div class="col-md-4">
                        <div class="col-md-12 form-group">
                            <div class="col-md-4">Wage Process for:</div>
                            <div class="col-md-8">
                                <b> @Model.wageProcessVM.WAG_Full_Month()</b>
                            </div>
                        </div>
                        <div class="col-md-12 form-group">
                            <div class="col-md-4">For Client:</div>
                            <div class="col-md-8">
                                <b>@Model.client.CLI_Name</b>
                            </div>
                        </div>
                        <div class="col-md-12 form-group">
                            <div class="col-md-4">Choose Template:</div>
                            <div class="col-md-8">
                                <div class="radio-inline">
                                    @foreach (var template in ViewBag.templateList)
                                    {
                                        @Html.RadioButtonFor(s => s.Template, (int)template, (int)template == 0 ? (object)new { @checked = true, @id = (int)template } : new { @id = (int)template })@template
                                        <br />
                                    }
                                    @*@Html.ValidationMessageFor(x => x.Template, "", new { @class = "text-danger" })*@
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12 form-group">
                            <div class="col-md-4">Select File:</div>
                            <div class="col-md-8">
                                @Html.TextBoxFor(m => m.ExcelFile, new { @type = "file" }) @*@Html.ValidationMessageFor(x => x.ExcelFile, "", new { @class = "text-danger" })*@
                            </div>
                        </div>
                        <div class="col-md-12 m-t-20 text-center">
                            <input class="btn btn-primary" type="submit" value="Verify Excel File" />
                        </div>
                    </div>
                    <div class="col-md-8 text-left border-left">
                        <table class="table table-responsive-sm">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Description</th>
                                    <th>Payable</th>
                                </tr>
                            </thead>
                            <tr>
                                <td>A</td>
                                <td>Not <span>Is Present</span></td>
                                <td>No</td>
                            </tr>
                            <tr>
                                <td>P = I/II/III/G</td>
                                <td><span>Is Present</span></td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>PL= EL(or E/L) = CO(or C/O)</td>
                                <td>Not <span>Is Present</span></td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>WO or W/O</td>
                                <td>Not <span>Is Present</span> + Is Weeklyoff</td>
                                <td>Depends on client requirement</td>
                            </tr>
                            <tr>
                                <td>PW</td>
                                <td>Is Present + Is Weeklyoff</td>
                                <td>Yes + Depends on client requirement</td>
                            </tr>
                            <tr>
                                <td>HO = PH = NH</td>
                                <td>Not <span>Is Present</span> + Is Holiday</td>
                                <td>Depends on client requirement</td>
                            </tr>
                            <tr>
                                <td>PO = PN</td>
                                <td>Is Present + Is Holiday</td>
                                <td>Yes + Depends on client requirement</td>
                            </tr>
                            <tr>
                                <td>HF = P/2 = I/2 = II/2 = III/2 = G/2</td>
                                <td>Is Present + Is Halfday</td>
                                <td>0.5 Day</td>
                            </tr>
                            <tr>
                                <td>CP</td>
                                <td>Is Present + Is Nightshift</td>
                                <td>Yes</td>
                            </tr>
                            <tr>
                                <td>NC</td>
                                <td>Is Present + Is Nightshift + Is Holiday</td>
                                <td>Yes + Depends on client requirement</td>
                            </tr>
                            <tr>
                                <td>CW</td>
                                <td>Is Present+ Is Nightshift + Is Weeklyoff</td>
                                <td>Yes + Depends on client requirement</td>
                            </tr>
                        </table>
                    </div>

                </div>
            }
        </div>
    </div>
</div>
