@model List<RMERP.DAL.ViewModel.AttendanceVM>
@using RMERP.DAL.Models;
@using RMERP.DAL.ViewModel;

@{
    ViewData["Title"] = "View Attendance";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

<div class="content container-fluid">
    <div class="row">
        <div class="col-sm-12">
            <h4 class="page-title">@ViewData["Title"]</h4>
        </div>
    </div>
    <div class="row">
        <div class="col-sm-12">
            <h5>
                Client:
                @ViewBag.ClientName
            </h5>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="table-responsive">

                <table class="table table-striped custom-table m-b-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            @{
                                int counter = 0;
                                DateTime tmpDate = ViewBag.startDate;

                                while (ViewBag.endDate >= tmpDate)
                                {
                                    counter = counter + 1;
                                    <th> @tmpDate.Day</th>
                                    tmpDate = tmpDate.AddDays(1);
                                }
                            }
                            <th>Total Working Days</th>
                            <th>Total Extra Working Hours</th>

                        </tr>
                    </thead>
                    <tbody>
                        @{
                            List<Int32> EMP_Ids = Model.Select(m => m.employee.EMP_Id).Distinct().ToList();
                        }


                        @foreach (var EMP_Id in EMP_Ids)
                        {
                            EmployeeVM employee = Model.Where(a => a.EMP_Id == EMP_Id).Select(m => m.employee).First();
                            Designations designation = Model.Where(a => a.EMP_Id == EMP_Id).Select(m => m.designation).First();
                            <tr>
                                <td><b>@employee.EMP_FullName</b><br />@designation.DES_Title</td>
                                @{
                                    int counter1 = 0;
                                    DateTime tmpDate1 = ViewBag.startDate;
                                    int totWorkingDays = 0;
                                    double totExtraWorkingHours = 0;
                                    while (ViewBag.endDate >= tmpDate1)
                                    {
                                        counter1 = counter1 + 1;
                                        AttendanceVM att = Model.Where(m => m.EMP_Id == EMP_Id && m.ATT_Date.Equals(tmpDate1)).FirstOrDefault();

                                        if (att != null)
                                        {

                                            <td>
                                                <div class="row" onmouseover="mousehover(@att.ATT_Id);" onmouseout="mouseout();">
                                                    @{
                                                        String str = "";
                                                        if (att.ATT_IsWeeklyOff)
                                                        {
                                                            str = "<span style='color:Orange;'>W/O</span>";
                                                        }
                                                        else
                                                        {
                                                            if (att.ATT_IsPresent)
                                                            {
                                                                str = "<span style='color:green;'>P</span>";
                                                            }
                                                            else
                                                            {
                                                                str = "<span style='color:red;'>A</span>";
                                                            }
                                                        }
                                                    }
                                                    <div class="col-md-12">@Html.Raw(str)</div>
                                                    <div class="col-md-12">
                                                        @{
                                                            if (att.ATT_ExtraHoursWorked == 0)
                                                            {
                                                                @Html.Raw("&nbsp;");
                                                            }
                                                            else
                                                            {
                                                                @att.ATT_ExtraHoursWorked.ToString("#.#")
                                                            }
                                                        }
                                                    </div>
                                                    <div class="col-md-12">
                                                        <a class="editatt edit_@att.ATT_Id" href='@Url.Action("EditAttendanceRecord","WageProcess",new { attId=att.ATT_Id})' title="Edit"><i class="fa fa-pencil m-r-5"></i></a>
                                                    </div>
                                                </div>
                                            </td>
                                            if (att.ATT_IsPresent == true)
                                            {
                                                totWorkingDays++;
                                            }
                                            if (att.ATT_ExtraHoursWorked > 0)
                                            {
                                                totExtraWorkingHours += att.ATT_ExtraHoursWorked;
                                            }

                                        }
                                        else
                                        {
                                            <td>
                                                -
                                            </td>
                                        }

                                        tmpDate1 = tmpDate1.AddDays(1);
                                    }

                                }

                                <td>@totWorkingDays Days</td>
                                <td>@totExtraWorkingHours Hours</td>

                            </tr>
                        }

                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section scripts{
<script type="text/javascript">
    $(document).ready(function () {
        $('.editatt').css("visibility", "hidden");
    });
    function mousehover(id) {
        $('.edit_' + id).css("visibility", "visible");
    }
    function mouseout() {
        $('.editatt').css("visibility", "hidden");
    }
</script>
}