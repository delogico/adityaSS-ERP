@model RMERP.DAL.ViewModel.AttendanceRegisterVM
@using RMERP.DAL.Models
@using RMERP.DAL.ManagerClasses
@{
    ViewData["Title"] = "AttendanceRegister";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

@section scripts{
    <script>
        $(document).ready(function () {
            debugger;
            $(".tab-content").hide();
        });

            function openClient(evt, CliName) {
                    debugger;
                    var i, tabcontent, tablinks;
                    tabcontent = document.getElementsByClassName("tabcontent");
                    for (i = 0; i < tabcontent.length; i++) {
                        tabcontent[i].style.display = "none";
                    }
                    tablinks = document.getElementsByClassName("tablinks");
                    for (i = 0; i < tablinks.length; i++) {
                        tablinks[i].className = tablinks[i].className.replace(" active", "");
                }
                $(".tab-content").show();
                    document.getElementById(CliName).style.display = "block";
                    evt.currentTarget.className += " active";
                }
    </script>
}

<ul class="nav nav-tabs">
    @foreach (var item in Model.listClients)
    {
        <li><a data-toggle="tab" class="tablinks" onclick="openClient(event,'@item.CLI_Name')">@item.CLI_Name</a></li>
    }
</ul>

<div class="tab-content">
   
    @foreach (var item in Model.listClients)
    {
        <div id="@item.CLI_Name" class="tabcontent">
            <h3>@item.CLI_Name</h3>
            @if (item.Clients_Employees != null)
            {
                <table class="table table-border">
                    <thead>
                        <tr>
                            <td>Employee ID</td>
                            <td>Employee Name</td>
                            <td>Designation</td>
                            <td>Date Of Joining</td>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            RMERPContext _context = new RMERPContext();
                            EmployeeManager empMgr = new EmployeeManager(_context);

                        }
                        @foreach (var emp in item.Clients_Employees.OrderBy(m => m.EMP_Id))
                        {
                        <tr>
                            @{Employees employees = new Employees();
                                employees = @empMgr.GetEmployeesById(emp.EMP_Id);}
                            <td>@employees.EMP_Id</td>
                            <td>@employees.EMP_FirstName</td>
                            <td>@employees.EMP_Designation</td>
                            <td>@emp.CLE_RegisteredOn.ToShortDateString()</td>
                        </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

</div>

