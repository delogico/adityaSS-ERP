@model Tuple<List<RMERP.DAL.ViewModel.AttendanceSummaryVM>, RMERP.DAL.Models.Client>@using RMERP.DAL.Models;@using RMERP.DAL.ViewModel;@{	ViewData["Title"] = "View Attendance";	Layout = "~/Views/Shared/_RMLayout.cshtml";	Wage_Process wage_ = ViewBag.Wage_Process;}@section Breadcrumbs {		<li class="breadcrumb-item">@Html.ActionLink("Wage Process", "Index", "WageProcess", new { FRM_Id = wage_.FRM_Id })</li>		<li class="breadcrumb-item">@Html.ActionLink("Wage Attendance", "WageAttendanceList", "Attendance", new { WAG_Id = wage_.WAG_Id })</li>		<li class="breadcrumb-item">View Attendance</li>}<div class="content container-fluid">	<div class="row">		<div class="col-sm-12">			<h3 class="page-title">@ViewData["Title"] ( @ViewBag.WAG_Month )</h3>		</div>	</div>	<div class="row">		<div class="col-sm-12">			<h5>				Client:				@Model.Item2.CLI_Name			</h5>		</div>	</div>	<div class="row">		<div class="col-md-12">			<div class="table-responsive">				<table class="table table-striped custom-table m-b-0 font11">					<thead>						<tr>							<th>Name</th>							<th>Present Days</th>							<th>Weekly Off</th>							<th>Public Holidays</th>							<th>Earn Leaves</th>							<th>Night Shifts</th>							<th>Total Extra Hours</th>						</tr>					</thead>					<tbody>						@foreach (var employee in Model.Item1.Select(m => m.Employee))						{							AttendanceSummaryVM summaryVM = Model.Item1.Where(e => e.EMP_Id == employee.EMP_Id).FirstOrDefault();								<tr>									<td><b>@employee.EMP_FullName</b><br />@employee.EMP_Designation</td>									<td>@summaryVM.ATS_PresentDays</td>									<td>@summaryVM.ATS_WeekOff</td>									<td>@summaryVM.ATS_PublicHolidays</td>									<td>@summaryVM.ATS_EarnLeaves</td>									<td>@summaryVM.ATS_NightShifts</td>									<td>@summaryVM.ATS_ExtraHours</td>								</tr>						}					</tbody>				</table>			</div>		</div>	</div></div>@section scripts {		<script type="text/javascript">			$(document).ready(function () {				$('.editatt').css("visibility", "hidden");			});			function mousehover(id) {				$('.edit_' + id).css("visibility", "visible");			}			function mouseout() {				$('.editatt').css("visibility", "hidden");			}		</script>}