@model RMERP.DAL.ViewModel.WageProcessClientAttendancePageVM
@using RMERP.DAL.Models;
@using RMERP.Helpers;

@{
   ViewData["Title"] = "Attendance status";
   Layout = "~/Views/Shared/_RMLayout.cshtml";
   int cnt = 0;
}
@section Breadcrumbs{
   <li class="breadcrumb-item">@Html.ActionLink("Wage Process", "Index", "WageProcess", new { FRM_Id = Model.wageProcess.FRM_Id })</li>
   <li class="breadcrumb-item">Wage Attendance</li>
}
<div class="content container-fluid">
   <div class="row">
      <div class="col-sm-8">
         <h3 class="page-title">@ViewData["Title"]  (@Model.wageProcess.FRM_Title/@Model.wageProcess.WAG_Full_Month() )</h3>
      </div>
   </div>
   @if (Model.IsOld)
         {
            <div class="alert alert-danger text-center"><b>The Selected Wage Month belong to old system of Attendance (before 03/25). You only can view the Attendance Data by clicking on "View" link to individual client.</b></div>
         }
   <div class="row">
      <div class="col-md-12">
         <div>
            <table class="table table-striped custom-table m-b-0" id="WAG_Table">
               <thead>
                  <tr>
                     <th></th>
                     <th></th>
                     @if (Model.IsOld)
                     {
                        <th class="text-center">Daily Attendance (Old)</th>
                     }
                     else
                     {
                        <th style="background-color:#DCDCDC;text-align:center;" colspan="4" align="center">Attendance Summary (New)</th>
                     }
                  </tr>
                  <tr>
                     <th>#</th>
                     <th>Client</th>
                     @if (Model.IsOld)
                     {
                        <th></th>
                     }
                     else
                     {
                        <th style="background-color:#EFEFEF;" class="text-center">Total Employee</th>
                        <th style="background-color:#EFEFEF;" class="text-center">Status</th>
                        <th style="background-color:#EFEFEF;"></th>
                        <th style="background-color:#EFEFEF;"></th>
                     }
                  </tr>
               </thead>
               <tbody>
                  @foreach (var item in Model.lstClient.OrderBy(o => o.CLI_Name))
                  {
                     cnt = cnt + 1;
                     <tr>
                        <td>@cnt</td>
                        <td><b>@item.CLI_Name</b></td>

                        @if (Model.IsOld)
                        {
                           <td class="text-center">
                              <a class="text-success" href='@Url.Action("Attendances", "Attendance", new { WAG_Id = Model.wageProcess.WAG_Id, CLI_Id = item.CLI_Id })' title="View"><i class="fa fa-eye m-r-5"></i> View</a>
                           </td>
                        }
                        else
                        {
                           <td style="background-color:#EFEFEF;" class="text-center">@(item.totalEmployees > 0 ? item.totalEmployees.ToString() : "-")</td>
                           <td style="background-color:#EFEFEF;" class="text-center">@Html.Raw((item.totalEmployees > 0 ? "<span class='label label-success-border'>Imported</span>" : "<span class='label label-danger-border'>Not Imported yet</span>"))</td>
                           <td style="background-color:#EFEFEF;" class="text-center">
                              @{
                                 if (item.totalEmployees > 0)
                                 {
                                    <a class="text-success" href='@Url.Action("Attendances", "Attendance", new { WAG_Id = Model.wageProcess.WAG_Id, CLI_Id = item.CLI_Id })' title="View"><i class="fa fa-eye m-r-5"></i> View</a>
                                 }
                                 else
                                 {
                                    <span>
                                       <a href='@Url.Action("UploadExcel", "Attendance", new { WAG_Id = Model.wageProcess.WAG_Id, CLI_Id = item.CLI_Id })' title="Upload">
                                          <i class="fa fa-upload m-r-5"></i> Upload
                                       </a>
                                    </span>
                                 }
                              }
                           </td>
                           <td style="background-color:#EFEFEF;" class="text-center">
                              @{
                                 if (item.totalEmployees > 0)
                                 {
                                    Wage_Process_Client wage = Model.wageProcess.wage_Process_Clients.Where(m => m.CLI_Id.Equals(item.CLI_Id)).FirstOrDefault();
                                    if (wage != null)
                                    {
                                       <span class='label label-warning-border'>Wage is already registed on  @DateHelper.getLongDateFormat(wage.WPC_SavedOn)</span>
                                    }
                                    else
                                    {
                                       <a onclick="return window.confirm('Are you sure, All attendance of this client will be deleted for this Wage Month?')"
                                          href='@Url.Action("DeleteWageClientAttendanceList", "Attendance", new { WAG_Id = Model.wageProcess.WAG_Id, CLI_Id = item.CLI_Id })' title="Reset" class="text-danger">
                                          <i class="fa fa-recycle m-r-5"></i> Reset Attendance
                                       </a>
                                    }
                                 }
                              }
                           </td>
                        }
                     </tr>
                  }
               </tbody>
            </table>
         </div>
      </div>
   </div>
</div>
@section scripts{
   @if (TempData["err"] != null)
   {
      <script>
         $(document).ready(function () {
         alert('@TempData["err"]');
     });
      </script>
   }
   <script>
      $('#WAG_Table').dataTable({ "paging": false, "ordering": false });
   </script>
}