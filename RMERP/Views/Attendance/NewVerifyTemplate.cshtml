@model RMERP.DAL.ViewModel.ATT_ExcelVM
@using RMERP.DAL.ViewModel
@using RMERP.Helpers;
@using RMERP.DAL.Models;
@{
    ViewData["Title"] = "Verify Excel File";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}
@section Breadcrumbs{
    <li class="breadcrumb-item">@Html.ActionLink("Wage Process", "NewIndex", "WageProcess", new { FRM_Id = Model.FRM_Id })</li>
    <li class="breadcrumb-item">@Html.ActionLink("Upload Attendance Excel", "NewUploadExcel", "Attendance", new { WAG_Id = Model.WAG_Id, CLI_Id = Model.CLI_Id })</li>
    <li class="breadcrumb-item">Verify Attendance</li>
}
@if (Model == null)
{
    <h4>No data to display</h4>
}
else
{
    <div class="modal-dialog modelLeftSide" style="width: 100%;">
        <button type="button" class="close" data-dismiss="modal">&times;</button>
        <div class="modal-content modal-lg" style="width: 98%;">
            <div class="modal-header">
                <div class="row">
                    <div class="col-md-7">
                        <h4 class="modal-title">Summary of Attendance Going to import</h4>
                        <h6 class="modal-title">Total Employee Found: @Model.TotalEmployees</h6>
                    </div>
                    <div class="col-md-5">
                        <h6 class="modal-title">Starting Date: @DateHelper.getLongDateFormat(Model.StartDate)</h6>
                        <h6 class="modal-title">Ending Date: @DateHelper.getLongDateFormat(Model.EndDate)</h6>
                    </div>
                </div>
            </div>
            <div class="modal-body">
                <div class="content container-fluid">
                    <div class="row">
                        <div class="col-md-12">

                            @if (Model.ExcelRows != null)
                            {
                                <div class="table-responsive">
                                    <table class="table table-striped font11" style="width: 100%;">
                                        <thead>
                                            <tr>
                                                <th>Id</th>
                                                <th>Employee</th>
                                                <th>Present Days</th>
                                                <th>Weekly Off</th>
                                                <th>Holidays</th>
                                                <th>Earn Leaves</th>
                                                <th>Night Shifts</th>
                                                <th>Total Extra Hours</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (ExcelRowVM Row in Model.ExcelRows)
                                            {
                                               <tr class="@(Model.NotExistsInClient.Any(e=>e.EMP_Id == Convert.ToInt32(Row.EMP_Id)) ? "text-muted" : "")">
                                                    <td>@Row.EMP_Id</td>
                                                    <td><b>@Row.EMP_Name</b><br />@Row.Designation</td>
                                                    <td>@Row.TotalPresenceDays</td>
                                                    <td>@Row.TotalWeeklyOff</td>
                                                    <td>@Row.TotalHolidays</td>
                                                    <td>@Row.TotalEarnLeave</td>
                                                    <td>@Row.TotalNightshift</td>
                                                    <td>@Row.TotalExtraHours</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p>No Record</p>
                            }                            
                            @if (Model.NotExistsInClient.Count() > 0 || Model.RemainingEmployees.Count() > 0)
                            {
                                <br />
                                <div class="row well well-lg" style="color:red;">
                                    <div class="col-md-12">
                                        <h4 class="modal-title">Match with client's Requirement</h4>
                                        <hr />
                                        <ul>
                                            @if (Model.NotExistsInClient.Count() > 0)
                                            {
                                                <li>
                                                    <b>We have found this employees which is/are not assign to Client:</b><br />Solution: Go to client Employees secion and Assign First
                                                    <ul>
                                                        @foreach (var item in Model.NotExistsInClient)
                                                        {
                                                            <li>@item.EMP_FirstName @item.EMP_MiddleName @item.EMP_SurName</li>
                                                        }
                                                        </ul>
                                                    </li>
                                            }
                                            @if (Model.RemainingEmployees.Count() > 0)
                                            {
                                                <li>
                                                    <b>We have found this missing employees which is/are assigned to Client:</b><br />
                                                    Solution: Re-verify Excel sheet you choosed.
                                                    <ul>
                                                    @foreach (var item in Model.RemainingEmployees)
                                                        {
                                                            <li> @item.EMP_FirstName @item.EMP_MiddleName @item.EMP_SurName</li>
                                                        }
                                                    </ul>
                                                </li>
                                            }
                                          </ul>
                                        </div>
                                    </div>
                                }
                            @using (Html.BeginForm("NewImportExcel", "Attendance", FormMethod.Post, new { @id = "form" }))
                            {
                                @Html.HiddenFor(m => m.WAG_Id)
                                @Html.HiddenFor(m => m.CLI_Id)
                                @Html.HiddenFor(m => m.FileName)
                                <div class="m-t-20 text-center">
                                    <input type="submit" value="Export To Database" name="Export" id="btnSubmit" class="btn btn-success" @(Model.IsEnableExport ? "" : "disabled") />
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section scripts{
    @if (TempData["err"] != null)
    {
        <script>
            $(document).ready(function () {
                alert('@TempData["err"]');
        });
        </script>
    };
    <script>
        $(document).on('invalid-form.validate', 'form', function () {
            var button = $(this).find('input[type="submit"]');
            setTimeout(function () {
                button.removeAttr('disabled');
            }, 1);
        });
        $(document).on('submit', 'form', function () {
            var button = $(this).find('input[type="submit"]');
            setTimeout(function () {
                button.attr('disabled', 'disabled');
            }, 0);
        });

    </script>
}