@model RMERP.DAL.ViewModel.ExcelViewModel
@using RMERP.Helpers;
@using RMERP.DAL.Helpers;
@using RMERP.DAL.Models;
@{
   ViewData["Title"] = "Verify Excel File";
   Layout = "~/Views/Shared/_RMLayout.cshtml";
   DateOnly tmpDate = ProjectUtils.DateTimeToDate(Model.startDate);
   DateOnly EndDate = ProjectUtils.DateTimeToDate(Model.endDate);
}
@section Breadcrumbs{
   <li class="breadcrumb-item">@Html.ActionLink("Wage Process", "Index", "WageProcess", new { FRM_Id = Model.FRM_Id })</li>
   <li class="breadcrumb-item">@Html.ActionLink("Upload Attendance Excel", "UploadExcel", "Attendance", new { WAG_Id = Model.WAG_Id, CLI_Id = Model.CLI_Id })</li>
   <li class="breadcrumb-item">Verify Attendance</li>
}

@if (Model == null)
{
   <h4>No data to display</h4>
}
else
{
   <div class="modal-dialog modelLeftSide" style="width: 100%;">
      <button type="button" class="close" data-dismiss="modal">&times;</button>
      <div class="modal-content modal-lg" style="width: 98%;">
         <div class="modal-header">
            <div class="row">
               <div class="col-md-7">
                  <h4 class="modal-title">Summary of Attendance Going to import</h4>
                  <h6 class="modal-title">Total Employee Found: @Model.totalEmployees</h6>
                  <h6 class="modal-title">Total Public Holidays: @Model.totalPublicHolidays</h6>
               </div>
               <div class="col-md-5">
                  <h6 class="modal-title">Starting Date: @DateHelper.getLongDateFormat(Model.startDate)</h6>
                  <h6 class="modal-title">Ending Date: @DateHelper.getLongDateFormat(Model.endDate)</h6>
               </div>
            </div>
         </div>
         <div class="modal-body">
            <div class="content container-fluid">
               <div class="row">
                  <div class="col-md-12">

                     @if (Model.excelRows != null)
                     {
                        <div class="table-responsive">
                           <table class="table table-striped font11" style="width: 100%;">
                              <thead>
                                 <tr>
                                    <th>Id</th>
                                    <th>Employee</th>
                                    @{
                                       while (EndDate >= tmpDate)
                                       {
                                          <th> @tmpDate.Day</th>
                                          tmpDate = tmpDate.AddDays(1);
                                       }
                                    }
                                    <th>Present Days</th>
                                    <th>Weekly Off</th>
                                    <th>Public Holidays</th>
                                    <th>Earn Leaves</th>
                                    <th>Night Shifts</th>
                                    <th>Total Extra Hours</th>
                                    @*<th>Total Paybale Days</th>*@
                                 </tr>
                              </thead>
                              <tbody>
                                 @foreach (var item in Model.excelRows)
                                 {
                                    <tr>
                                       <td>@item.EMP_Id</td>
                                       <td><b>@item.EMP_Name</b><br />@item.Designation</td>
                                       @{
                                          tmpDate = new(Model.startDate.Year, Model.startDate.Month, Model.startDate.Day);
                                          while (EndDate >= tmpDate)
                                          {
                                             Attendance att = Model.listAttendance.Where(m => m.EMP_Id == Convert.ToInt32(item.EMP_Id) && m.ATT_Date.Equals(tmpDate)).FirstOrDefault();
                                             if (att != null)
                                             {
                                                <td align="center">
                                                   <div class="row">
                                                      @{
                                                         String str = "";
                                                         String strSecondrow = "";
                                                         if (att.ATT_IsPresent)
                                                         {
                                                            if (att.ATT_IsHalfday)
                                                            {
                                                               if (att.ATT_Shift != null)
                                                               {
                                                                  str = "<span class='present'>" + att.ATT_Shift + "</span>";
                                                               }
                                                               else
                                                               {
                                                                  str = "<span class='present'>P/2</span>";
                                                               }
                                                            }
                                                            else
                                                            {
                                                               if (att.ATT_Shift != null)
                                                               {
                                                                  str = "<span class='present'>" + att.ATT_Shift + "</span>";
                                                               }
                                                               else
                                                               {
                                                                  str = "<span class='present'>P</span>";
                                                               }
                                                            }

                                                         }
                                                         else
                                                         {
                                                            str = "<span class='absent'>A</span>";
                                                         }

                                                         <div class="col-md-12">@Html.Raw(str)</div>
                                                         if (att.ATT_IsPublicHoliday)
                                                         {
                                                            strSecondrow = " <span class='present'>PH</span>";
                                                         }
                                                         else if (att.ATT_IsEarnLeave)
                                                         {
                                                            strSecondrow = "<span class='present'>EL</span>";
                                                         }
                                                         else if (att.ATT_IsWeeklyOff)
                                                         {
                                                            strSecondrow = " <span class='present'>WO</span>";
                                                         }
                                                         <div class="col-md-12">
                                                            @if (strSecondrow != "")
                                                            {
                                                               @Html.Raw(strSecondrow)
                                                            }
                                                            else
                                                            {
                                                               @Html.Raw("&nbsp;")
                                                            }
                                                         </div>
                                                         <div class="col-md-12 font10">
                                                            @{
                                                               if (att.ATT_ExtraHoursWorked > 0)
                                                               {
                                                                  @att.ATT_ExtraHoursWorked.ToString("#.#")
                                                               }
                                                               else
                                                               {
                                                                  @Html.Raw("&nbsp;")
                                                               }
                                                               if (att.ATT_NightShift)
                                                               {
                                                                  @Html.Raw(" <i class='fa fa-moon-o'></i>")
                                                               }
                                                            }
                                                         </div>
                                                      }
                                                   </div>
                                                </td>
                                             }
                                             tmpDate = tmpDate.AddDays(1);
                                          }
                                       }
                                       <td>@item.totalPresenceDays</td>
                                       <td>@item.totalWeeklyOff</td>
                                       <td>@item.totalHolidays</td>
                                       <td>@item.TotalEarnLeave</td>
                                       <td>@item.TotalNightshift</td>
                                       <td>@item.TotalExtraHours</td>
                                       @*<td>@item.totalPaybleDays</td>*@
                                    </tr>
                                 }
                              </tbody>
                           </table>
                        </div>
                     }
                     else
                     {
                        <p>No Record</p>
                     }
                     @if (Model.empListExtraInExcel != null && Model.EmpListExtraInDb != null)
                     {
                        @if (Model.empListExtraInExcel.Count() > 0 || Model.EmpListExtraInDb.Count() > 0 || Model.datePeriod == false)
                        {
                           <br />
                           <div class="row well well-lg" style="color:red;">
                              <div class="col-md-12">
                                 <h4 class="modal-title">Match with client's Requirement</h4>
                                 <hr />
                                 <ul>
                                    @if (Model.empListExtraInExcel.Count() > 0)
                                    {
                                       <li>
                                          <b>We have found this employees which is/are not assign to Client:</b><br />Solution: Go to client Employees secion and Assign First
                                          <ul>
                                             @foreach (var item in Model.empListExtraInExcel)
                                             {
                                                <li> @item.EMP_FirstName @item.EMP_MiddleName @item.EMP_SurName</li>
                                             }
                                          </ul>
                                       </li>
                                    }
                                    @if (Model.EmpListExtraInDb.Count() > 0)
                                    {
                                       <li>
                                          <b>We have found this missing employees which is/are assigned to Client:</b><br />
                                          Solution: Re-verify Excel sheet you choosed.
                                          <ul>
                                             @foreach (var item in Model.EmpListExtraInDb)
                                             {
                                                <li> @item.EMP_FirstName @item.EMP_MiddleName @item.EMP_SurName</li>
                                             }
                                          </ul>
                                       </li>
                                    }
                                    @if (Model.datePeriod == false)
                                    {
                                       <li>
                                          <b>We have found date period of excel is not match with client parameter.</b><br />
                                          Solution: Check Client parameter and excel sheet again.
                                       </li>
                                    }
                                 </ul>
                              </div>
                           </div>
                        }
                     }
                     @using (Html.BeginForm("ImportExcel", "Attendance", FormMethod.Post, new { @id = "form" }))
                     {
                        @Html.HiddenFor(m => m.WAG_Id)
                        @Html.HiddenFor(m => m.CLI_Id)
                        @Html.HiddenFor(m => m.fileName)
                        @Html.HiddenFor(m => m.Template)
                        <div class="m-t-20 text-center">
                           <input type="submit" value="Export To Database" name="Export" id="btnSubmit" class="btn btn-success" @(Model.btnExportToDatabase ? "" : "disabled") />
                        </div>
                     }
                  </div>
               </div>
            </div>
         </div>
      </div>
   </div>
}

@section scripts{
   @if (TempData["err"] != null)
   {
      <script>
            $(document).ready(function () {
                alert('@TempData["err"]');
        });
      </script>
   };
   <script>
      $(document).on('invalid-form.validate', 'form', function () {
         var button = $(this).find('input[type="submit"]');
         setTimeout(function () {
            button.removeAttr('disabled');
         }, 1);
      });
      $(document).on('submit', 'form', function () {
         var button = $(this).find('input[type="submit"]');
         setTimeout(function () {
            button.attr('disabled', 'disabled');
         }, 0);
      });

   </script>
}

