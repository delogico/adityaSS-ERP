                                                                        @Html.CheckBox("OT_ESIC", new { @class = "OTDeductSelection", @value = "ESIC" })
                                                                    }
                                                                    @Html.Raw("ESIC")
                                                                </div>
                                                            </div>*@
                                                    </div>

                                                </div>
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        @Html.TextBoxFor(m => m.CRI_OT_Formula, new { @class = "form-control" })
                                                        <p class="errorFormula manualError"></p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="m-t-20 text-center">
