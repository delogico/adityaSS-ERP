@model RMERP.DAL.ViewModel.ClientRequirementsModel
@using static RMERP.DAL.App_Code.ProjectUtils;

@{
    ViewData["Title"] = "Add-Edit Requirement";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

@section scripts{
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>
    <script>
        $(document).ready(function () {
            debugger;
            var id = $("#CriId").val();
            if (id > 0) {
                //$("#DesId").prop("disabled", true);
                $('#DesId').attr("disabled", true); 
            }
            var tab = $("#tabName").val();
            if (tab == "History" || tab =="ViewRequirement") {
                $('select', 'form').attr('disabled', true).attr('readonly', true);
                $('input', 'form').attr('disabled', true).attr('readonly', true);
                $('button', 'form').attr('disabled', true).attr('readonly', true);
            }
        });
    </script>
    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {
            alert('@TempData["message"]');
        });
    </script>
};


}
@*<div id="add_contact" class="modal custom-modal fade" role="dialog">*@
<div class="modal-dialog">
    <div class="modal-content modal-lg">
        <div class="modal-header">
            <h4 class="modal-title"> @ViewData["Title"]</h4>
        </div>
        <div class="modal-body">
            <div class="m-b-30">
                @using (Html.BeginForm("AddEditRequirement", "Clients", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.CriId)
                    if (Model.CriId > 0)
                    {
                        @Html.HiddenFor(m => m.DesId, new { @id = "designationID" })
                    }
                    @Html.HiddenFor(m => m.CriActive)
                    @Html.HiddenFor(m => m.CliId)
                    @Html.HiddenFor(m => m.tabName)
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                @Html.LabelFor(m => m.DesId, new { @class = "control-label" })
                                @Html.DropDownListFor(m => m.DesId, new SelectList(ViewBag.Designation, "DesId", "DesTitle"), "Select Designation", new { @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.DesId, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-group">
                                @Html.LabelFor(m => m.CliName, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.CliName, new { @readonly = "readonly", @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.CliName, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.CriBasic, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.CriBasic, new { @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.CriBasic, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.CriDa, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.CriDa, new { @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.CriDa, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
