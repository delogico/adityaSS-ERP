                                                            {
                                                                arrOT = Model.CRI_OT_Formula.Substring(0, Model.CRI_OT_Formula.IndexOf("-")).Split('+');
                                                                arrDeductOT = Model.CRI_OT_Formula.Substring(Model.CRI_OT_Formula.IndexOf("-") + 1).Split('-');
                                                            }
                                                            else
                                                            {
                                                                arrOT = Model.CRI_OT_Formula.Split('+');
                                                            }
                                                        }
                                                    }
