                                                                {
                                                                    @Html.CheckBox("OT_HRA", new { @class = "OTselection", @value = "HRA", @checked = "checked" })
                                                                }
                                                                else
                                                                {
                                                                    @Html.CheckBox("OT_HRA", new { @class = "OTselection", @value = "HRA" })
                                                                }
                                                                @Html.Raw("HRA")
                                                            </div>

                                                            @for (var i = 0; i < Model.allAllowances.Count; i++)
                                                            {
                                                                if (Model.allAllowances[i].flagClientRequirement == true)
                                                                {
                                                                    <div class="col-md-12">
                                                                        @if (arrOT != null && arrOT.Contains(Model.allAllowances[i].allowance.ALL_Shortform))
                                                                        {
                                                                            @Html.CheckBox(@Model.allAllowances[i].allowance.ALL_Shortform, new { @class = "OTselection", @value = Model.allAllowances[i].allowance.ALL_Shortform, @checked = "checked" })
                                                                        }
                                                                        else
                                                                        {
                                                                            @Html.CheckBox(@Model.allAllowances[i].allowance.ALL_Shortform, new { @class = "OTselection", @value = Model.allAllowances[i].allowance.ALL_Shortform })
                                                                        }
                                                                        @Html.Raw(Model.allAllowances[i].allowance.ALL_Title)

                                                                    </div>
                                                                }
                                                            }
                                                        </div>
                                                        @*<div class="col-md-6" >
                                                                <div class="col-md-12">
                                                                    @if (arrDeductOT != null && arrDeductOT.Contains("PF"))
                                                                    {
                                                                        @Html.CheckBox("OT_PF", new { @class = "OTDeductSelection", @value = "PF", @checked = "checked" })
                                                                    }
                                                                    else
                                                                    {
                                                                        @Html.CheckBox("OT_PF", new { @class = "OTDeductSelection", @value = "PF" })
                                                                    }
                                                                    @Html.Raw("PF")

