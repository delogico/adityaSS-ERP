                                    </label>
                                    <label class="radio-inline">
                                        @Html.RadioButtonFor(m => m.CriWageCalculationOnWeeklyOffPlus, false) No
                                    </label>

                                </label>
                                @Html.ValidationMessageFor(x => x.CriWageCalculationOnWeeklyOffPlus, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>

                    <div class="m-t-20 text-center">
                        <button class="btn btn-primary">Submit</button>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

