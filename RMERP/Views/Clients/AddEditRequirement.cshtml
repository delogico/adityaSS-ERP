                                                            else
                                                            {
                                                                @Html.CheckBox(Model.allAllowances[i].allowance.ALL_Shortform, new { @class = "Billingselection", @Value = Model.allAllowances[i].allowance.ALL_Shortform })
                                                            }
                                                            @Html.Raw(@Model.allAllowances[i].allowance.ALL_Title)
                                                        </div>
                                                    }
                                                }

                                            </div>
                                            @Html.TextBoxFor(m => m.CRI_Billing_ServiceCharge_Formula, new { @class = "form-control" })
                                        </div>
                                    </div>
                                </div>


                            </div>
                        </div>
                        <div id="RegDate" class="tab-pane">
                            <div class="row">
                                <div class="col-md-10">
                                    <div class="alert alert-info">This Version of Requirement will be effective from the Month selected in this date. And will be being effective till we have a New Version.</div>
                                    @if (Model.IsMajorModified)
                                    {
                                        <div class="alert alert-warning">Last Record Registerd on @DateHelper.getLongDateFormat(Model.LastRecordRegOn)</div>
                                    }
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.CRI_RegisteredOn, new { @class = "control-label" })
                                        @Html.EditorFor(m => m.CRI_RegisteredOn, new { htmlAttributes = new { @class = "form -control" } })
                                    </div>

                                    @if (Model.CRI_InactivatedOn != null)
                                    {
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.CRI_InactivatedOn, new { @class = "control-label" })
                                            @Html.EditorFor(m => m.CRI_InactivatedOn, new { htmlAttributes = new { @class = "form -control" } })
                                        </div>
                                    }

                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="m-t-20 text-center">
                        <button type="submit" class="btn btn-primary btnSave">Save</button>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

@section scripts{

    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-validator/0.5.3/js/bootstrapValidator.js"></script>
    @if (Model.CRI_Id > 0)
    {
        <script src="~/assets/Scripts/requirement_Edit.js"></script>
    }
    else
    {
        <script src="~/assets/Scripts/requirement.js"></script>
    }
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>

    <script>
        $(document).ready(function () {

            var tab = GetParameterValues("tab");
            function GetParameterValues(param) {
                var url = window.location.href.slice(window.location.href.indexOf('?') + 1).split('&');
                for (var i = 0; i < url.length; i++) {
                    var urlparam = url[i].split('=');
                    if (urlparam[0] == param) {
                        return urlparam[1];
                    }
                }
            };

            $("#divProffTax").hide();
            if ($("#CRI_ProfessionalTax").prop("checked")) {
                $("#divProffTax").show();
            }

            if (tab == "History" || tab == "ViewRequirement") {
                $('select', 'form').attr('disabled', true).attr('readonly', true);
                $('input', 'form').attr('disabled', true).attr('readonly', true);
                $('button', 'form').attr('disabled', true).attr('readonly', true);
            }
            $('input[class="Allselection"]').click(function () {
                if ($(this).prop("checked") == true) {
                    $("#divReqAllow_" + this.id).show();
                    addCheckbox(this.id);
                    $("#flagClientRequirement" + this.id).val("true");
                }
                else if ($(this).prop("checked") == false) {
                    $("#divReqAllow_" + this.id).hide();
                    $("#chk_" + this.id).remove();
                    $("#lbl_" + this.id).remove();
                    $("#br" + this.id).remove();
                    $("#flagClientRequirement" + this.id).val("false");
                }
            });
            var PFSelection = [];
            var ESICSelection = [];
            var BillingSelection = [];
            var OTSelection = [];
            var OTDeductSelection = [];
            if ($("#CRI_PF_Formula").val() != "") {
                PFSelection = $("#CRI_PF_Formula").val().split("+");
            }
            if ($("#CRI_ESIC_Formula").val() != "") {
                ESICSelection = $("#CRI_ESIC_Formula").val().split("+");
            }
            if ($("#CRI_OT_Formula").val() != "") {
                var OT_Formula = $("#CRI_OT_Formula").val();

                if (($("#CRI_OT_Formula").val().includes("-"))) {
                    OTSelection = OT_Formula.substring(0, OT_Formula.indexOf('-')).split("+");
                    OTDeductSelection = OT_Formula.substring(OT_Formula.indexOf('-') + 1).split("-");
                } else {
                    OTSelection = OT_Formula.split("+");
                }

            }
            if ($("#CRI_Billing_ServiceCharge_Formula").val() != "") {
                var Billing_Formula = $("#CRI_Billing_ServiceCharge_Formula").val();
                BillingSelection = Billing_Formula.split("+");

            }
            $(document).on("click", "INPUT[class^=PFselection]", function (event) {
                if ($(this).prop("checked") == true) {
                    PFSelection.push($(this).prop('value'));
                }
                else if ($(this).prop("checked") == false) {
                    PFSelection.splice(PFSelection.indexOf($(this).prop('value')), 1)
                }
                $("#CRI_PF_Formula").val(PFSelection.join("+"));
            });
            $(document).on("click", "INPUT[class^=ESICselection]", function (event) {
                if ($(this).prop("checked") == true) {
                    ESICSelection.push($(this).prop('value'));
                }
                else if ($(this).prop("checked") == false) {
                    ESICSelection.splice(ESICSelection.indexOf($(this).prop('value')), 1)
                }
                $("#CRI_ESIC_Formula").val(ESICSelection.join("+"));
            });
            $(document).on("click", "INPUT[class^=Billingselection]", function (event) {
                if ($(this).prop("checked") == true) {
                    BillingSelection.push($(this).prop('value'));
                }
                else if ($(this).prop("checked") == false) {
                    BillingSelection.splice(BillingSelection.indexOf($(this).prop('value')), 1)
                }
                $("#CRI_Billing_ServiceCharge_Formula").val(BillingSelection.join("+"));
            });
            $(document).on("click", "INPUT[class^=OTselection]", function (event) {
                calculateFormula();
            });
            $(document).on("click", "INPUT[class^=OTDeductSelection]", function (event) {
                calculateFormula();
            });

            function calculateFormula() {
                var str = "";
                $("INPUT[class=OTselection]")  // for all checkboxes
                    .each(function () {  // first pass, create name mapping
                        if (this.checked) {
                            str = str + (str.length > 0 ? "+" : "") + this.value;
                        }
                    });
                $("INPUT[class=OTDeductSelection]")  // for all checkboxes
                    .each(function () {  // first pass, create name mapping
                        if (this.checked) {
                            str = str + "-" + this.value;
                        }
                    });

                $("#CRI_OT_Formula").val(str);
            }


            function addCheckbox(AllId) {
                var id = parseInt(AllId);
                var container = $('#PFlist');
                var containerEsic = $('#ESIClist');
                var containerOT = $('#OTlist');
                var containerDeductOT = $('#OTDeductlist');
                var containerBilling = $('#Billinglist');
                var short = $("#allAllowances_" + (parseInt(id) - 1) + "__allowance_ALL_Shortform");
                var all = $("#allAllowances_" + (parseInt(id) - 1) + "__allowance_ALL_Title");
                var id = 'PF_' + short.val();
                container.append("<div class='col-md-12'><input type='checkbox' class='PFselection' id='" + id + "' value='" + short.val() + "' />" + all.val() + "</div>")
                containerEsic.append("<div class='col-md-12'><input type='checkbox' class='ESICselection' id='" + id + "' value='" + short.val() + "' />" + all.val() + "</div>")
                containerOT.append("<div class='col-md-12'><input type='checkbox' class='OTselection' id='" + id + "' value='" + short.val() + "' />" + all.val() + "</div>")
                containerDeductOT.append("<div class='col-md-12'><input type='checkbox' class='OTDeductSelection' id='" + id + "' value='" + short.val() + "' />" + all.val() + "</div>")
                containerBilling.append("<div class='col-md-12'><input type='checkbox' class='Billingselection' id='" + id + "' value='" + short.val() + "' />" + all.val() + "</div>")
            }

        });
        $("input[id='rdo_OT_Payable']").click(function () {
            $("#divOTdifferently").hide();
            $("#divByFormula").hide();
            $("#div_OT_Per_Hr").hide();
            $('#rdo_OT_Payable').val("True");
        });
        $("input[id='rdo_OT_Differently']").click(function () {
            $("#divOTdifferently").show();
            $("#divByFormula").hide();
            $("#div_OT_Per_Hr").show();
            $('#rdo_OT_Payable').val("False");
        });
        $("input[id='rdo_OT_Fixed_Amount']").click(function () {
            $("#divOTdifferently").show();
            $("#divByFormula").hide();
            $("#div_OT_Per_Hr").show();
            $('#rdo_OT_Payable').val("False");
            $('#rdo_OT_Fixed_Amount').val("True");

        });
        $("input[id='rdo_OT_By_Formula']").click(function () {
            $("#divOTdifferently").show();
            $("#divByFormula").show();
            $("#div_OT_Per_Hr").hide();
            $('#rdo_OT_Payable').val("False");
            $('#rdo_OT_Fixed_Amount').val("False");
        });
        $('input[id="chkOutStation"]').click(function () {

            if ($(this).prop("checked") == true) {
                $("#divOutStaion").show();
                var name = "OSL";
                addCheckboxNewAllowance(name);
                $("#CRI_OutStation_Allowance").val("true");
            }
            else if ($(this).prop("checked") == false) {
                $("#divOutStaion").hide();
                $("#CRI_OutStation_Allowance").val("false");
            }
        });
        $('input[id="chkNightshift"]').click(function () {

            if ($(this).prop("checked") == true) {
                $("#divNightshift").show();
                var name = "NSL";
                addCheckboxNewAllowance(name);
                $("#CRI_Nightshift_Allowance").val("true");
            }
            else if ($(this).prop("checked") == false) {
                $("#divNightshift").hide();
                $("#CRI_Nightshift_Allowance").val("false");
            }
        });
        $('input[id="chkAttendance"]').click(function () {
            if ($(this).prop("checked") == true) {
                $("#divAttendance").show();
                var name = "AAL";
                addCheckboxNewAllowance(name);
                $("#CRI_Attendance_Allowance").val("true");
            }
            else if ($(this).prop("checked") == false) {
                $("#divAttendance").hide();
                $("#CRI_Attendance_Allowance").val("false");
            }
        });
        $('input[id="chkPerformance"]').click(function () {
            if ($(this).prop("checked") == true) {
                var name = "PAL";
                addCheckboxNewAllowance(name);
                $("#CRI_Performance_Allowance").val("true");
            }
            else if ($(this).prop("checked") == false) {
                $("#CRI_Performance_Allowance").val("false");
            }
        });

        $("input[id='CRI_ProfessionalTax']").click(function () {

            if ($(this).prop("checked") == true) {
                $("#divProffTax").show();
            } else {
                $("#divProffTax").hide();
            }
        });

        function addCheckboxNewAllowance(allowance) {
            var container = $('#PFlist');
            var containerEsic = $('#ESIClist');
            var containerOT = $('#OTlist');
            var containerDeductOT = $('#OTDeductlist');
            container.append("<div class='col-md-12'><input type='checkbox' class='PFselection' id='" + allowance + "' value='" + allowance + "' />" + allowanceName(allowance) + "</div>")
            containerEsic.append("<div class='col-md-12'><input type='checkbox' class='ESICselection' id='" + allowance + "' value='" + allowance + "' />" + allowanceName(allowance) + "</div>")
            containerOT.append("<div class='col-md-12'><input type='checkbox' class='OTselection' id='" + allowance + "' value='" + allowance + "' />" + allowanceName(allowance) + "</div>")
            containerDeductOT.append("<div class='col-md-12'><input type='checkbox' class='OTDeductSelection' id='" + allowance + "' value='" + allowance + "' />" + allowanceName(allowance) + "</div>")
        }
        function allowanceName(shortName) {
            switch (shortName) {
                case "OSL":
                    return "Out station Allowance";
                    break;
                case "AAL":
                    return "Attendance Allowance";
                    break;
                case "NSL":
                    return "Nightshift Allowance";
                    break;
                case "PAL":
                    return "Performance Allowance";
                    break;
                default:
                    return "";
            }
        }
        $('.HRAselection').change(function () {
            var value = $(this).filter(':checked').val();
            if (value == "True") {
                $("#CRI_HRA_Percentage").hide();
                $("#CRI_HRA_Fixed").show();
            }
            else if (value == "False") {
                $("#CRI_HRA_Percentage").show();
                $("#CRI_HRA_Fixed").hide();
            }
        });
        $(".btnSave").click(function () {
            var isCheckedPayable = $('#rdo_OT_Payable').prop('checked');
            if (isCheckedPayable == false) {
                var isCheckedFixed = $('#rdo_OT_Fixed_Amount').prop('checked');
                if (isCheckedFixed == false) {
                    if ($("#CRI_OT_Formula").val() == "") {
                        $(".errorFormula").html("Formula required");
                        return false;
                    }
                } else {
                    if ($("#CRI_OT_Fixed_PerHour").val() == "" || $("#CRI_OT_Fixed_PerHour").val() <= 0) {
                        $(".errorAmount").html("Amount required");
                        return false;
                    }
                }

            }
        });
        $("input[name='CRI_Billing_Type']").click(function () {
            var radioValue = $("input[name='CRI_Billing_Type']:checked").val();
            if (radioValue == 1) {
                $("#div_lumpsum_amount").show();
                $("#div_service_change_basic").hide();
            } else if (radioValue == 2) {
                $("#div_lumpsum_amount").hide();
                $("#div_service_change_basic").show();
            }
        });
        function ChangeEmployerMLWF(EmployerMLWF) {
            $("#CRI_MLWF_Employer_Max_Base").val(EmployerMLWF.value);
        }
        function ChangeEmployeeMLWF(EmployeeMLWF) {
            $("#CRI_MLWF_Employee_Max_Base").val(EmployeeMLWF.value);
        }
    </script>

    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {
                alert('@TempData["message"]');
        });
        </script>
    };

}