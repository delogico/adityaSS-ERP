                                                        <div class="col-md-6">
                                                            <div class="col-md-12">
                                                                @if (arrOT != null && arrOT.Contains("BASIC"))
                                                                {
                                                                    @Html.CheckBox("OT_BASIC", new { @class = "OTselection", @value = "BASIC", @checked = "checked" })
                                                                }
                                                                else
                                                                {
                                                                    @Html.CheckBox("OT_BASIC", new { @class = "OTselection", @value = "BASIC" })
                                                                }
                                                                @Html.Raw("BASIC")

                                                            </div>
                                                            <div class="col-md-12">
                                                                @if (arrOT != null && arrOT.Contains("DA"))
                                                                {
                                                                    @Html.CheckBox("OT_DA", new { @class = "OTselection", @value = "DA", @checked = "checked" })
                                                                }
                                                                else
                                                                {
                                                                    @Html.CheckBox("OT_DA", new { @class = "OTselection", @value = "DA" })
                                                                }
                                                                @Html.Raw("DA")
                                                            </div>
                                                            <div class="col-md-12">
