@model RMERP.DAL.ViewModel.ClientContactVM
@{
    ViewData["Title"] = "Add-Edit Contacts";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
    ViewBag.ButtonTitle = Model.CON_Id > 0 ? "Update Contact" : "Create Contact";
}
@section scripts{
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>

    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {
            alert('@TempData["message"]');
        });
        </script>
    };

}
<div class="modal-dialog">
    <div class="modal-content modal-md">
        <div class="modal-header">
            <h4 class="modal-title"> @ViewData["Title"]</h4>
        </div>
        <div class="modal-body">
            <div class="m-b-30">
                @using (Html.BeginForm("AddEditContacts", "Clients", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.CON_Id)
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.CON_FirstName, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.CON_FirstName, new { @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.CON_FirstName, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.CON_SurName, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.CON_SurName, new { @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.CON_SurName, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.CON_Designation, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.CON_Designation, new { @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.CON_Designation, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.CON_Mobile, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.CON_Mobile, new { @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.CON_Mobile, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.CON_Email, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.CON_Email, new { @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.CON_Email, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.CON_isPrimary, new { @class = "control-label" })
                                <label class="radio-inline form-control ">
                                    <label class="radio-inline">
                                        @Html.RadioButtonFor(m => m.CON_isPrimary, true, new { @checked = "checked" }) Yes
                                    </label>
                                    <label class="radio-inline">
                                        @Html.RadioButtonFor(m => m.CON_isPrimary, false) No
                                    </label>

                                </label>
                                @Html.ValidationMessageFor(x => x.CON_isPrimary, "", new { @class = "text-danger" })
                            </div>
                        </div>

                    </div>

                    <div class="m-t-20 text-center">
                        <button class="btn btn-primary">@ViewBag.ButtonTitle</button>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

