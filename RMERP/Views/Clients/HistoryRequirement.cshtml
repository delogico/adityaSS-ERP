@model RMERP.DAL.ViewModel.ClientRequirementsViewModel
@{
    ViewData["Title"] = "HistoryRequirement";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

@if (Model.ClientRequirementsList.Count()>0)
{
    @*<div class="col-sm-12">

            <div class="col-sm-8">
                <h4 class="page-title">@Model.ClientRequirementsModel.CliName</h4>
                </div><div class="col-sm-4">
            <h6>Designation -<b>@Model.ClientRequirementsModel.DesTitle</b></h6>
        </div>
        </div>*@
<div class="col-sm-8">
    <h4 class="page-title">@Model.ClientRequirementsModel.CliName</h4>
    <p><b>Designation - @Model.ClientRequirementsModel.DesTitle</b></p>
</div>
        <table class="table table-striped custom-table m-b-0 ">
            <thead>
                <tr>                   
                    <th>Basic/(Basic+DA)</th>
                    <th>Registered On</th>                    
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.ClientRequirementsList)
                {
                    <tr>                      
                        <td>@(Convert.ToDecimal(item.CriBasic) == (0.0m) ? item.CriBasicDa : (item.CriBasic + Convert.ToDecimal(item.CriDa)))</td>
                        <td>@item.CriRegisteredOn</td>                       
                        <td class="text-right">
                            <div class="dropdown">
                                <a href="#" class="action-icon dropdown-toggle" data-toggle="dropdown" aria-expanded="false"><i class="fa fa-ellipsis-v"></i></a>
                                <ul class="dropdown-menu pull-right">
                                    <li><a href='@Url.Action("AddEditRequirement","Clients",new { criId=item.CriId,tab="History"})' title="ViewRequirement"><i class="fa fa-pencil m-r-5"></i> View </a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }

            </tbody>
        </table>
        }
        else
        {
        <p>No History To Display</p>
        }
