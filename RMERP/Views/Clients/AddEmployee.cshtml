@model RMERP.DAL.ViewModel.ClientEmployeeVM
@{
    ViewData["Title"] = "Employees";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}
@section Breadcrumbs{
    <li class="breadcrumb-item">@Html.ActionLink("Clients", "Index", "Clients")</li>
    <li class="breadcrumb-item">@Html.ActionLink("Client Info", "AddEditClients", "Clients", new { id = Model.CLI_Id })</li>
    <li class="breadcrumb-item">Assign Employee</li>
}
@section scripts{
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            CLE_Id = $('#CLE_Id').val();
            if (CLE_Id > 0) {
                $("#EMP_Id").attr('disabled', true).attr('readonly', true);
                $("#DES_Id").attr('disabled', true).attr('readonly', true);
            }
            $('.selectpicker').selectpicker({
                liveSearch: true,
                showSubtext: true
            });

            $(document).on('invalid-form.validate', 'form', function () {               
                var button = $(this).find('input[type="submit"]');
                setTimeout(function () {
                    button.removeAttr('disabled');
                }, 1);
            });
            $(document).on('submit', 'form', function () {                
                var button = $(this).find('input[type="submit"]');
                setTimeout(function () {
                    button.attr('disabled', 'disabled');
                }, 0);
            });
        });


    </script>
}
<div class="modal-dialog modelLeftSide">
    <button type="button" class="close" data-dismiss="modal">&times;</button>
    <div class="modal-content modal-lg">
        <div class="modal-header">
            <h4 class="modal-title">@ViewBag.ClientName</h4>
        </div>
        <div class="modal-body">
            <div class="m-b-30">
                @using (Html.BeginForm("ClientEmployee", "Clients", FormMethod.Post, new { @id = "frm" }))
                {
                    @Html.HiddenFor(m => m.CLE_Id)
                    @Html.HiddenFor(m => m.CLI_Id)
                    @Html.HiddenFor(m => m.Old_DES_Id)
                    @Html.HiddenFor(m => m.CLE_UnassignedOn)
                    @Html.HiddenFor(m => m.CLE_ReassignedOn)
                    @Html.HiddenFor(m => m.ADM_Id_UnassignedBy)

                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_Id, new { @class = "control-label" })
                                @Html.DropDownListFor(x => x.EMP_Id, new SelectList(ViewBag.EmployeeList, "EMP_Id", "EMP_FullName"), "Select Employee", new { @class = "form-control selectpicker",
                               //onchange = "this.form.submit();",
                               data_show_subtext = "true",
                               data_live_search = "true"
                           })
                                @Html.ValidationMessageFor(x => x.EMP_Id, "", new { @class = "text-danger" })

                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-group">
                                @Html.LabelFor(m => m.DES_Id, new { @class = "control-label" })
                                @Html.DropDownListFor(x => x.DES_Id, new SelectList(ViewBag.designationList, "DES_Id", "DES_Title"), "Select Designation", new { @class = "form-control selectpicker" ,
                               //onchange = "this.form.submit();",
                               data_show_subtext = "true",
                               data_live_search = "true"
                           })
                                @Html.ValidationMessageFor(x => x.DES_Id, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-group">
                                @Html.LabelFor(m => m.CLE_RegisteredOn, new { @class = "control-label" })
                                @Html.EditorFor(m => m.CLE_RegisteredOn, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(x => x.CLE_RegisteredOn, "", new { @class = "text-danger" })
                            </div>
                            <div class="alert alert-warning"> Employee will be available in wage from the selected date's month till it unassign.</div>
                        </div>

                    </div>

                    <div class="m-t-20 text-center">
                        <input type="submit" id="submit" class="btn btn-primary" value="Save Changes" />
                    </div>
                }

            </div>
        </div>
    </div>
</div>





