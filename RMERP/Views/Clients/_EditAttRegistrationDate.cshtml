@model RMERP.DAL.ViewModel.AttendanceParameterVM

@section scripts{
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>
}
<div id="AttRegDateModal" class="modal fade" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content modal-md">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title"> Change Date</h4>
            </div>
            <div class="modal-body">
                @using (Html.BeginForm("EditAttRegDate", "Clients", FormMethod.Post))
                {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })                   

                <div class="form-group">
                    @Html.HiddenFor(m => m.ATP_Id)
                    @Html.HiddenFor(m => m.CLI_Id)
                    @Html.HiddenFor(m => m.ATP_Att_MonthReal)
                    @Html.HiddenFor(m => m.ATP_Att_Month_Start)
                    @Html.HiddenFor(m => m.ATP_Att_Month_End)

                    @Html.Label("Registration Date")
                    @Html.EditorFor(m => m.ATP_RegisteredOn, new { htmlAttributes = new { @class = "form -control" } })
                    @Html.ValidationMessageFor(model => model.ATP_RegisteredOn, "", new { @class = "text-danger" })
                </div>

                <div class="m-t-20 text-center">
                    <input type="submit" name="Submit" id="btnSubmit" class="btn btn-primary" />
                </div>
                }
            </div>
        </div>
    </div>
</div>

