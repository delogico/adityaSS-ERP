@model RMERP.DAL.ViewModel.ClientsEmployeesViewModel
@{
    ViewData["Title"] = "ClientEmployee";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

@section scripts{
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>
}
    <div class="modal-dialog modelLeftSide">
        <button type="button" class="close" data-dismiss="modal">&times;</button>
        <div class="modal-content modal-lg">
            @*<div class="col-sm-12">
                    <h4 class="page-title"></h4>
                </div>*@
            <div class="modal-header">
                <h4 class="modal-title">@ViewBag.ClientName</h4>
            </div>
            <div class="modal-body">
                <div class="m-b-30">
                    @using (Html.BeginForm("ClientEmployee", "Clients", FormMethod.Post))
                    {
                        @Html.HiddenFor(m => m.CleId)
                        @Html.HiddenFor(m => m.CliId)

                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    @Html.LabelFor(m => m.EmpId, new { @class = "control-label" })
                                    @Html.DropDownListFor(x => x.EmpId, new SelectList(ViewBag.EmployeeList, "EmpId", "EmpFirstName"), "Select Employee", new { @class = "form-control" })
                                    @Html.ValidationMessageFor(x => x.EmpId, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="form-group">
                                    @Html.LabelFor(m => m.DesId, new { @class = "control-label" })
                                    @Html.DropDownListFor(x => x.DesId, new SelectList(ViewBag.designationList, "DesId", "DesTitle"), "Select Designation", new { @class = "form-control" })
                                    @Html.ValidationMessageFor(x => x.DesId, "", new { @class = "text-danger" })
                                </div>
                            </div>

                        </div>

                        <div class="m-t-20 text-center">
                            <input type="submit" class="btn btn-primary" value="Save Changes" />
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>

