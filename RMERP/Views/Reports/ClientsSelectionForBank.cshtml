@model RMERP.DAL.ViewModel.ClientSelectionVM

@using static RMERP.DAL.Helpers.ProjectUtils;
@{
    ViewData["Title"] = "Bank Reports";
Layout = "~/Views/Shared/_RMLayout.cshtml";
}
@section Breadcrumbs{
    <li class="breadcrumb-item">@Html.ActionLink("Wage Process", "Index", "WageProcess", new { FRM_Id = Model.FRM_Id })</li>
    <li class="breadcrumb-item">Bank Reports</li>
}

<style>
    .modal-dialog {
        transform: translate(0, -50%);
        top: 30%;
        margin: 0 auto;
    }
</style>
@section scripts{

    <script>
        $(document).ready(function () {
           
            $("#checkAll").prop('checked', $(this).prop('checked'));
            $(".check").prop('checked', true);
        });
        $("#checkAll").click(function () {
            $(".check").prop('checked', $(this).prop('checked'));
        });
    </script>
}
<div>
    <div class="content container-fluid">
        <div class="row">
            <div class="col-sm-8">
                <h4 class="page-title">@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-4 text-right m-b-30">

            </div>
        </div>
        <div class="row">
            <div class="col-md-10">
                <div>
                    @Html.Label("Select Client")<br />
                    @using (Html.BeginForm("Bank_Reports", "Reports", FormMethod.Post))
                    {
                        <div class="row well well-lg">
                            <div class="checkbox">
                                <label>
                                    <input type="checkbox" class="check" id="checkAll"> <strong>Select All Clients</strong>
                                </label>
                            </div>
                            @for (var i = 0; i < Model.selectionVMs.Count; i++)
                            {
                                <div class="col-sm-6 client-selection-model">
                                    @Html.HiddenFor(m => Model.selectionVMs[i].WAG_Id)
                                    @Html.HiddenFor(m => Model.selectionVMs[i].CLI_Id)
                                    @Html.HiddenFor(m => Model.selectionVMs[i].CLI_Name)
                                    <label class="check-client">
                                        @Html.CheckBoxFor(m => Model.selectionVMs[i].IsSelect, new { id = Model.selectionVMs[i].CLI_Id, @class = "check" })
                                        @Html.DisplayFor(m => Model.selectionVMs[i].CLI_Name, new { @class = "form-control" })
                                    </label>
                                </div>
                            }
                        </div>                       
                        <div class="row">
                            <div class="col-md-10">
                                <div class="form-group">
                                    @Html.LabelFor(m => m.Report, new { @class = "control-label" })<br />
                                    <label class="radio-inline well well-sm ">
                                        @foreach (var BANK_REPORT_TYPE in Enum.GetValues(typeof(BANK_REPORT_TYPE)).Cast<BANK_REPORT_TYPE>())
                                        {
                                            <label class="radio-inline report-type">
                                                @Html.RadioButtonFor(s => s.Report, (int)BANK_REPORT_TYPE, new { @class = "control-label" })@GetStringValue(BANK_REPORT_TYPE)
                                            </label><br />
                                        }
                                    </label>
                                    @Html.ValidationMessageFor(x => x.Report, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-10">
                                <div class="form-group text-center">
                                    <input type="submit" value="Generate Report" id="btnSubmit" class="btn btn-primary" />
                                </div>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>