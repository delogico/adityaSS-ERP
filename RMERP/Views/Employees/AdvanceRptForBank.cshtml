@model IEnumerable<RMERP.DAL.ViewModel.EmployeeAdvanceVM>
@using RMERP.Helpers
@{
    ViewData["Title"] = "Advance Report For Bank";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}
@section Breadcrumbs{
<li class="breadcrumb-item">@Html.ActionLink("Wage Process", "Index", "WageProcess", new { FRM_Id = ViewBag.FRM_Id })</li>
    <li class="breadcrumb-item">Advance Taken</li>
}
@section scripts{
    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {
            alert('@TempData["message"]');
        });
        </script>
    };

}
<style>
    .modal-dialog {
        transform: translate(0, -50%);
        top: 30%;
        margin: 0 auto;
    }
</style>
<div>
    <div class="content container-fluid">
        <div class="row">
            <div class="col-sm-8">
                <h4 class="page-title">@ViewBag.FRM_Name (@ViewBag.WAG_Month)</h4>
            </div>
            <div class="col-sm-4 text-right m-b-30">
                @*<a class="btn btn-primary rounded" href="@Url.Action("AddEditDesignation","Designations")"><i class="fa fa-plus"></i> Register New Designation</a>*@
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div>
                    <table class="table table-striped custom-table">
                        <thead>
                            <tr>
                                <th>Employee Name</th>
                                <th>Advance Amount</th>
                                <th>Advance Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.EmployeeName</td>
                                    <td>@item.ADV_Amount</td>
                                    <td>@DateHelper.getDateWithFormat(item.ADV_RegisteredOn)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
