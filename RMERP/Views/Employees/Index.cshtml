@model IEnumerable<RMERP.DAL.ViewModel.EmployeeVM>
@using RMERP.Helpers
@{
    ViewData["Title"] = "Employees";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

@section scripts{
    @if (TempData["message"] != null)
    {
        <script>
        $(document).ready(function () {
            alert('@TempData["message"]');
        });
        </script>
    };

}
<style>
    .modal-dialog {
        transform: translate(0, -50%);
        top: 30%;
        margin: 0 auto;
    }
</style>
<div>
    <div class="content container-fluid">
        <div class="row">
            <div class="col-sm-8">
                <h4 class="page-title">@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-4 text-right m-b-30">
                <a class="btn btn-primary rounded" href="@Url.Action("AddEditEmployee","Employees")"><i class="fa fa-plus"></i> Add New Employee</a>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                @if (Model.Count() > 0)
                {
                    <div>
                        <table class="table table-striped custom-table datatable">
                            <thead>
                                <tr>

                                    <th>Department</th>
                                    <th>Name</th>
                                    <th>DOB</th>
                                    <th>Designation</th>
                                    <th>Joining date</th>
                                    <th>M/F</th>
                                    <th>Mobile</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>

                                        <td>@item.DEPT_Title</td>
                                        <td>@item.EMP_FullName</td>
                                        <td>@DateHelper.getDateWithFormat(@item.EMP_DOB)</td>
                                        <td>@item.EMP_Designation</td>
                                        <td>@DateHelper.getDateWithFormat(@item.EMP_DateOfJoining)</td>
                                        <td>@item.EMP_MoF</td>
                                        <td>@item.EMP_Contact_Primary</td>
                                        <td class="text-right">
                                            <div class="dropdown">
                                                <a href="#" class="action-icon dropdown-toggle" data-toggle="dropdown" aria-expanded="false"><i class="fa fa-ellipsis-v"></i></a>
                                                <ul class="dropdown-menu pull-right">
                                                    <li><a href='@Url.Action("AddEditEmployee","Employees",new { EMP_Id=item.EMP_Id})' title="Edit"><i class="fa fa-pencil m-r-5"></i> Edit</a></li>
                                                    <li><a href='@Url.Action("ActiveEmployee","Employees",new { EMP_Id=item.EMP_Id})' title="Active/InActive"><i class="fa fa-trash m-r-5"></i> Active/InActive</a></li>
                                                    <li><a href='@Url.Action("AddEditEmployee","Employees",new { EMP_Id=item.EMP_Id, tab="View"})' title="Edit"><i class="fa fa-eye m-r-5"></i> View</a></li>
                                                </ul>
                                            </div>
                                        </td>
                                    </tr>
                                }

                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <P>No Employees registered.</P>
                }

            </div>
        </div>
    </div>
</div>

