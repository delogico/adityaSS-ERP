@model IEnumerable<RMERP.DAL.Models.Employees>
@using static RMERP.DAL.App_Code.ProjectUtils;

@{
    ViewData["Title"] = "Employee List";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

@section scripts{
    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {
            alert('@TempData["message"]');
        });
        </script>
    };

}
<style>
    .modal-dialog {
        transform: translate(0, -50%);
        top: 30%;
        margin: 0 auto;
    }
</style>
<div>
    <div class="content container-fluid">
        <div class="row">
            <div class="col-sm-8">
                <h4 class="page-title">@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-4 text-right m-b-30">
                <a class="btn btn-primary rounded" href="@Url.Action("AddEditEmployee","Employees")"><i class="fa fa-plus"></i> Add New Employee</a>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                @if (Model.Count() > 0)
                {
                    <div>
                        <table class="table table-striped custom-table datatable">
                            <thead>
                                <tr>
                                  
                                    <th>Department Name</th>
                                    <th>Name</th>
                                    <th>DOB</th>
                                    <th>Designation</th>
                                    @*<th>Marital</th>*@
                                    <th>Date Of Joining</th>
                                    <th>Gender</th>
                                    <th>Contact No</th>

                                    @*<th>Employee Number</th>
                                    <th>TPC EmployeeID</th>
                                    <th>Activation</th>*@

                                    <th class="text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                <tr>
                                    
                                    <td>@item.Dept.DeptTitle</td>
                                    <td>@item.EmpFirstName&nbsp;@item.EmpMiddleName&nbsp;@item.EmpSurName</td>

                                    <td>@item.EmpDob</td>
                                    <td>@item.EmpDesignation</td>
                                    @*<td>@(item.EmpMarried == (byte)MaritalStatus.Married ? "Married" : "UnMarried")</td>*@

                                    <td>@item.EmpDateOfJoining</td>
                                    <td>@(item.EmpGender == true ? "Male" : "Female")</td>
                                    <td>@item.EmpContactPrimary</td>

                                    @*<td>@item.EmpEmployeeNumberOffice</td>
                                    <td>@item.EmpTpcEmployeeId</td>
                                    <td>@item.EmpIsActive</td>*@
                                    <td class="text-right">
                                        <div class="dropdown">
                                            <a href="#" class="action-icon dropdown-toggle" data-toggle="dropdown" aria-expanded="false"><i class="fa fa-ellipsis-v"></i></a>
                                            <ul class="dropdown-menu pull-right">
                                                <li><a href='@Url.Action("AddEditEmployee","Employees",new { EmpID=item.EmpId})' title="Edit"><i class="fa fa-pencil m-r-5"></i> Edit</a></li>
                                                <li><a href='@Url.Action("ActiveEmployee","Employees",new { EmpID=item.EmpId})' title="Active/InActive"><i class="fa fa-trash m-r-5"></i> Active/InActive</a></li>
                                                <li><a href='@Url.Action("AddEditEmployee","Employees",new { EmpID=item.EmpId, tab="View"})' title="Edit"><i class="fa fa-pencil m-r-5"></i> View</a></li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                                }

                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <P>No Employees To Display</P>
                }

            </div>
        </div>
    </div>
</div>

