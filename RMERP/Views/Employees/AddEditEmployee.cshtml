                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div id="EmployeeAdvance" class="tab-pane fade">            
            <div>
                <div class="content container-fluid">
                    <div class="row">
                        <div class="col-sm-8">
                            <h4 class="page-title">Employee Advance</h4>
                        </div>
                        <div class="col-sm-4 text-right m-b-30">
                            <a class="btn btn-primary rounded" href="@Url.Action("AddEditAdvance","Employees")"><i class="fa fa-plus"></i> Add New Advance</a>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div>
                                <table class="table table-striped custom-table m-b-0">
                                    <thead>
                                        <tr>
                                            <td>Employee Name</td>
                                            <td>Advance Amount</td>
                                            <td>Date</td>
                                            <td>Action</td>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.ListEmployee_Advance.Count()>0)
                                        {
                                            @foreach (var item in Model.ListEmployee_Advance)
                                            {
                                                <tr>
                                                    <td>@item.EMP_.EMP_FirstName @item.EMP_.EMP_MiddleName @item.EMP_.EMP_SurName </td>
                                                    <td>@item.ADV_Amount </td>
                                                    <td>@item.ADV_RegisteredOn </td>
                                                    <td class="text-right">
                                                        <div class="dropdown">
                                                            <a href="#" class="action-icon dropdown-toggle" data-toggle="dropdown" aria-expanded="false"><i class="fa fa-ellipsis-v"></i></a>
                                                            <ul class="dropdown-menu pull-right">
                                                                <li><a href='@Url.Action("AddEditAdvance","Employees",new { ADV_Id=item.ADV_Id})' title="Edit"><i class="fa fa-pencil m-r-5"></i> Edit</a></li>
                                                                <li><a href='@Url.Action("DeleteAdvance","Employees",new { ADV_Id=item.ADV_Id})' title="Delete" onclick="return confirm('Are you sure?');"><i class="fa fa-trash m-r-5"></i> Delete</a></li>
                                                            </ul>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }


                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div id="KitInfo" class="tab-pane fade">
            <h3>Kit Information</h3>
            <p>Kit information of Employee</p>
        </div>        
    </div>
