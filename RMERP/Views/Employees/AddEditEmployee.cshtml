@model RMERP.DAL.ViewModel.EmployeeAddEditVM
@using static RMERP.DAL.App_Code.ProjectUtils;

@{
    ViewData["Title"] = "Add-Edit Employee";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

@section scripts{
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>



    <link rel="stylesheet" href="//code.jquery.com/ui/1.11.4/themes/smoothness/jquery-ui.css">
    <script src="//code.jquery.com/jquery-1.10.2.js"></script>
    <script src="//code.jquery.com/ui/1.11.4/jquery-ui.js"></script>
    <script>
        $(document).ready(function () {
            debugger;

            EMP_Id = $('#employeeViewModel_EMP_Id').val();
            if (EMP_Id == 0) {
                $('.nav li').not('.active').addClass('disabled');
                $('.nav li').not('.active').find('a').removeAttr("data-toggle");
            } else {
                $('.nav li').not('.active').removeClass('disabled');
            }

            var tab = GetParameterValues('tab'); 
            var EMP_Id = GetParameterValues('EMP_Id'); 
            if (tab == "View") {
                $('select', 'form').attr('disabled', true).attr('readonly', true);
                $('input', 'form').attr('disabled', true).attr('readonly', true);
            }
            if (tab == "AddEditAdvance") {
                debugger;
                var CurrentActive = $('.nav li.active').find("a").attr("href");
                var NextActive = $('.nav li.active').next('li').find("a").attr("href");

                $('.nav li.active').next('li').addClass("active");
                $('.nav li.active').prev('li').removeClass("active");
                $(CurrentActive).removeClass("in active");  
                $(NextActive).addClass("in active");
            }
            
        });
        function GetParameterValues(param) {
            var url = window.location.href.slice(window.location.href.indexOf('?') + 1).split('&');
            for (var i = 0; i < url.length; i++) {
                var urlparam = url[i].split('=');
                if (urlparam[0] == param) {
                    return urlparam[1];
                }
            }
        };
        
    </script>
    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {
            alert('@TempData["message"]');
        });
        </script>
    };

}

    <h3>@Model.employeeViewModel.EMP_FullName</h3>    
    <ul class="nav nav-tabs">
        <li class="active"><a data-toggle="tab" href="#AddEditEmployee">Add-Edit Employee</a></li>
        <li><a data-toggle="tab" href="#EmployeeAdvance">Employee Advance</a></li>
        <li><a data-toggle="tab" href="#KitInfo">Kit Information</a></li>
    </ul>

    <div class="tab-content">
        <div id="AddEditEmployee" class="tab-pane fade in active">         
            <div class="modal-dialog modelLeftSide">
                <div class="modal-content modal-lg">
                    <div class="modal-header">
                        <h4 class="modal-title"> @ViewData["Title"]</h4>
                    </div>
                    <div class="modal-body">
                        <div class="m-b-30">
                            @using (Html.BeginForm("AddEditEmployee", "Employees", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                @Html.HiddenFor(m => m.employeeViewModel.EMP_Id)
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.DEPT_Id, new { @class = "control-label" })
                                            @Html.DropDownListFor(m => m.employeeViewModel.DEPT_Id, new SelectList(ViewBag.deptList, "DEPT_Id", "DEPT_Title"), "Select Department", new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.DEPT_Id, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_FirstName, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_FirstName, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_FirstName, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_MiddleName, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_MiddleName, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_MiddleName, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_SurName, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_SurName, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_SurName, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_Aadhar_Name, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_Aadhar_Name, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_Aadhar_Name, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_Aadhar_Number, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_Aadhar_Number, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_Aadhar_Number, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_DOB, new { @class = "control-label" })
                                            @Html.EditorFor(m => m.employeeViewModel.EMP_DOB, new { htmlAttributes = new { @class = "form-control" } })
                                            @*@Html.TextBoxFor(x => x.employeeViewModel.EmpDob, "{0:yyyy-MM-dd}", new { @class = "form-control", @type = "date", @value = System.DateTime.Now.ToShortDateString() })*@
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_DOB, "", new { @class = "text-danger" })
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_Married, new { @class = "control-label" })
                                            <label class="radio-inline form-control ">
                                                @foreach (var MaritalStatus in Enum.GetValues(typeof(MaritalStatus)))
                                                {
                                                    <label class="radio-inline">
                                                        @Html.RadioButtonFor(s => s.employeeViewModel.EMP_Married, (int)MaritalStatus, (int)MaritalStatus == 0 ? (object)new { @checked = true, @id = (int)MaritalStatus } : new { @id = (int)MaritalStatus })@MaritalStatus
                                                    </label>
                                                }
                                            </label>
                                            @Html.ValidationMessageFor(x => x.employeeViewModel.EMP_Married, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_DateOfJoining, new { @class = "control-label" })
                                            @Html.EditorFor(m => m.employeeViewModel.EMP_DateOfJoining, new { htmlAttributes = new { @class = "form-control" } })
                                            @*@Html.TextBoxFor(x => x.EmpDateOfJoining, "{0:yyyy-MM-dd}", new { @class = "form-control", @type = "date", @value = System.DateTime.Now })*@
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_DateOfJoining, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_Gender, new { @class = "control-label" })
                                            <label class="radio-inline form-control ">
                                                <label class="radio-inline">
                                                    @Html.RadioButtonFor(m => m.employeeViewModel.EMP_Gender, true, new { @checked = "checked" }) Male
                                                </label>
                                                <label class="radio-inline">
                                                    @Html.RadioButtonFor(m => m.employeeViewModel.EMP_Gender, false) Female
                                                </label>

                                            </label>
                                            @Html.ValidationMessageFor(x => x.employeeViewModel.EMP_Gender, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_Contact_Primary, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_Contact_Primary, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_Contact_Primary, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_Contact_Secondry, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_Contact_Secondry, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_Contact_Secondry, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_Address, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_Address, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_Address, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_Designation, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_Designation, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_Designation, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_Pan_Number, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_Pan_Number, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_Pan_Number, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_ESIC_Number, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_ESIC_Number, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_ESIC_Number, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_UAN_Number, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_UAN_Number, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_UAN_Number, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_EmployeeNumber_Office, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_EmployeeNumber_Office, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_EmployeeNumber_Office, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            @Html.LabelFor(m => m.employeeViewModel.EMP_TPC_EmployeeId, new { @class = "control-label" })
                                            @Html.TextBoxFor(m => m.employeeViewModel.EMP_TPC_EmployeeId, new { @class = "form-control" })
                                            @Html.ValidationMessageFor(m => m.employeeViewModel.EMP_TPC_EmployeeId, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <div class="col-md-6">
