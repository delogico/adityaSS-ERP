                                                        <a href='@Url.Action("DeleteAdvance","Employees",new { ADV_Id=item.ADV_Id, EMP_Id = Model.EMP_Id})' title="Delete" onclick="return confirm('Are you sure?');"><i class="fa fa-trash m-r-5"></i> Remove</a>
                                                    </td>
                                                }



                                            </tr>
                                        }
                                    }


                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="PaymentInfo" class="tab-pane fade">
        <div class="modal-dialog modelLeftSide">
            <div class="modal-content modal-lg">
                <div class="modal-body">
                    <div class="m-b-30">
                        @using (Html.BeginForm("AddEditEmployeesPaymentInfo", "Employees", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                            @Html.HiddenFor(m => m.EMP_Id)
                            <p class="div-title">Payment Type</p>
                            <br />
                            <div class="row col-md-12">
                                <div class="form-group">
                                    @Html.LabelFor(m => m.EMP_Payment_Type, new { @class = "control-label" })
                                    <label class="radio-inline form-control ">
                                        @foreach (var PAYMENT_TYPE in Enum.GetValues(typeof(PAYMENT_TYPE)).Cast<PAYMENT_TYPE>())
                                        {
                                            <label class="radio-inline">
                                                @Html.RadioButtonFor(s => s.EMP_Payment_Type, (int)PAYMENT_TYPE, (int)PAYMENT_TYPE == 0 ? (object)new { @checked = true, @id = (int)PAYMENT_TYPE, onclick = "PAYMENT_TYPE(this)" } : new { @id = (int)PAYMENT_TYPE, onclick = "PAYMENT_TYPE(this)" })@GetStringValue(PAYMENT_TYPE)
                                            </label>
                                        }
                                    </label>
                                    @Html.ValidationMessageFor(x => x.EMP_Payment_Type, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="row divBankType">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.EMP_Is_IDBI_Other, new { @class = "control-label" })
                                        <label class="radio-inline form-control ">
                                            @foreach (var PAYMENT_BANK_TYPE in Enum.GetValues(typeof(PAYMENT_BANK_TYPE)).Cast<PAYMENT_BANK_TYPE>())
                                            {
                                                <label class="radio-inline">
                                                    @Html.RadioButtonFor(s => s.EMP_Is_IDBI_Other, (int)PAYMENT_BANK_TYPE, (int)PAYMENT_BANK_TYPE == 0 ? (object)new { @checked = true, @id = (int)PAYMENT_BANK_TYPE, onclick = "PAYMENT_BANK_TYPE(this)" } : new { @id = (int)PAYMENT_BANK_TYPE, onclick = "PAYMENT_BANK_TYPE(this)" })@GetStringValue(PAYMENT_BANK_TYPE)
                                                </label>
                                            }
                                        </label>
                                        @Html.ValidationMessageFor(x => x.EMP_Is_IDBI_Other, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.EMP_Account_Name, new { @class = "control-label" })
                                        @Html.TextBoxFor(m => m.EMP_Account_Name, new { @class = "form-control" })
                                        @Html.ValidationMessageFor(m => m.EMP_Account_Name, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.EMP_Account_Number, new { @class = "control-label" })
                                        @Html.TextBoxFor(m => m.EMP_Account_Number, new { @class = "form-control" })
                                        @Html.ValidationMessageFor(m => m.EMP_Account_Number, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.EMP_Bank, new { @class = "control-label" })
                                        @if (Model.EMP_Bank == "IDBI BANK" || Model.EMP_Bank == "IDBI BANK LTD")
                                        {
                                            @Html.TextBoxFor(m => m.EMP_Bank, new { @class = "form-control", disabled = "disabled" })
                                        }
                                        else
                                        {
                                            @Html.TextBoxFor(m => m.EMP_Bank, new { @class = "form-control" })
                                        }
                                        @Html.ValidationMessageFor(m => m.EMP_Bank, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.EMP_Branch, new { @class = "control-label" })
                                        @Html.TextBoxFor(m => m.EMP_Branch, new { @class = "form-control" })
                                        @Html.ValidationMessageFor(m => m.EMP_Branch, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.EMP_Bank_IFSC, new { @class = "control-label" })
                                        @Html.TextBoxFor(m => m.EMP_Bank_IFSC, new { @class = "form-control" })
                                        @Html.ValidationMessageFor(m => m.EMP_Bank_IFSC, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                            </div>

                            <div class="m-t-20 text-center">
                                <input type="submit" name="Save" id="btnSubmit" class="btn btn-primary" />
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
