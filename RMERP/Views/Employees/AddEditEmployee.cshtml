@model RMERP.DAL.ViewModel.EmployeeViewModel
@using static RMERP.DAL.App_Code.ProjectUtils;

@{
    ViewData["Title"] = "Add-Edit Employee";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

@section scripts{
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>



    <link rel="stylesheet" href="//code.jquery.com/ui/1.11.4/themes/smoothness/jquery-ui.css">
    <script src="//code.jquery.com/jquery-1.10.2.js"></script>
    <script src="//code.jquery.com/ui/1.11.4/jquery-ui.js"></script>
    <script>
        $(document).ready(function () {
            debugger;
            var tab = GetParameterValues('tab'); 
            if (tab == "View") {
                //$('input', 'form').attr('readonly', true);
                $('select', 'form').attr('disabled', true).attr('readonly', true);
                $('input', 'form').attr('disabled', true).attr('readonly', true);
            }       
        });
        function GetParameterValues(param) {
            var url = window.location.href.slice(window.location.href.indexOf('?') + 1).split('&');
            for (var i = 0; i < url.length; i++) {
                var urlparam = url[i].split('=');
                if (urlparam[0] == param) {
                    return urlparam[1];
                }
            }
        };
        ////////////////////////////////////
        //$(document).ready(function () {
        //    // get date from MyDate input field
        //    var date = $(".my-date").val();

        //    // use current date as default, if input is empty
        //    if (!date) {
        //        date = new Date();
        //    }

        //    $('.my-date').datetimepicker({
        //        format: 'YYYY/MM/DD',
        //        date: date
        //    });
        //});
    </script>
    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {
            alert('@TempData["message"]');
        });
        </script>
    };

}
<div class="modal-dialog modelLeftSide">
    <div class="modal-content modal-lg">
        <div class="modal-header">
            <h4 class="modal-title"> @ViewData["Title"]</h4>
        </div>
        <div class="modal-body">
            <div class="m-b-30">
                @using (Html.BeginForm("AddEditEmployee", "Employees", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    @Html.HiddenFor(m => m.EMP_Id)
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.DEPT_Id, new { @class = "control-label" })
                                @Html.DropDownListFor(m => m.DEPT_Id, new SelectList(ViewBag.deptList, "DEPT_Id", "DEPT_Title"), "Select Department", new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.DEPT_Id, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_FirstName, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_FirstName, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_FirstName, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_MiddleName, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_MiddleName, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_MiddleName, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_SurName, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_SurName, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_SurName, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_Aadhar_Name, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_Aadhar_Name, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_Aadhar_Name, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_Aadhar_Number, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_Aadhar_Number, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_Aadhar_Number, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_DOB, new { @class = "control-label" })
                                @Html.EditorFor(m => m.EMP_DOB, new { htmlAttributes = new { @class = "form-control" } })
                                @*@Html.TextBoxFor(x => x.EmpDob, "{0:yyyy-MM-dd}", new { @class = "form-control", @type = "date", @value = System.DateTime.Now.ToShortDateString() })*@
                                @Html.ValidationMessageFor(m => m.EMP_DOB, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_Married, new { @class = "control-label" })
                                <label class="radio-inline form-control ">
                                    @foreach (var MaritalStatus in Enum.GetValues(typeof(MaritalStatus)))
                                    {
                                        <label class="radio-inline">
                                            @Html.RadioButtonFor(s => s.EMP_Married, (int)MaritalStatus, (int)MaritalStatus == 0 ? (object)new { @checked = true, @id = (int)MaritalStatus } : new { @id = (int)MaritalStatus })@MaritalStatus
                                        </label>
                                    }
                                </label>
                                @Html.ValidationMessageFor(x => x.EMP_Married, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_DateOfJoining, new { @class = "control-label" })
                                @Html.EditorFor(m => m.EMP_DateOfJoining, new { htmlAttributes = new { @class = "form-control" } })
                                @*@Html.TextBoxFor(x => x.EmpDateOfJoining, "{0:yyyy-MM-dd}", new { @class = "form-control", @type = "date", @value = System.DateTime.Now })*@
                                @Html.ValidationMessageFor(m => m.EMP_DateOfJoining, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_Gender, new { @class = "control-label" })
                                <label class="radio-inline form-control ">
                                    <label class="radio-inline">
                                        @Html.RadioButtonFor(m => m.EMP_Gender, true, new { @checked = "checked" }) Male
                                    </label>
                                    <label class="radio-inline">
                                        @Html.RadioButtonFor(m => m.EMP_Gender, false) Female
                                    </label>

                                </label>
                                @Html.ValidationMessageFor(x => x.EMP_Gender, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_Contact_Primary, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_Contact_Primary, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_Contact_Primary, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_Contact_Secondry, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_Contact_Secondry, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_Contact_Secondry, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_Address, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_Address, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_Address, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_Designation, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_Designation, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_Designation, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_Pan_Number, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_Pan_Number, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_Pan_Number, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_ESIC_Number, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_ESIC_Number, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_ESIC_Number, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_UAN_Number, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_UAN_Number, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_UAN_Number, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_EmployeeNumber_Office, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_EmployeeNumber_Office, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_EmployeeNumber_Office, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_TPC_EmployeeId, new { @class = "control-label" })
                                @Html.TextBoxFor(m => m.EMP_TPC_EmployeeId, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.EMP_TPC_EmployeeId, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(m => m.EMP_IsActive, new { @class = "control-label" })
                                @Html.CheckBoxFor(m => m.EMP_IsActive,new { @checked = "checked", @class = "control-label"})
                                @Html.ValidationMessageFor(x => x.EMP_IsActive, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>

                    <div class="m-t-20 text-center">
                        <input type="submit" name="Submit Employee" id="btnSubmit" class="btn btn-primary" />
                    </div>
                }

            </div>
        </div>
    </div>
</div>

