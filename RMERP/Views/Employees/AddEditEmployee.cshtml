    <div id="EmployeeDocuments" class="tab-pane fade">
        <div>
            <div class="content container-fluid">
                <div class="row" style="margin-bottom: 20px;margin-left: 2px;">
                    <div class="col-md-6" style="border: 1px solid #aaa; padding: 10px;">
                        @using (Html.BeginForm("AddEmployeeDocuments", "Employees", FormMethod.Post, new { enctype = "multipart/form-data" }))
                        {
                            @Html.HiddenFor(m => m.employee_Document.EMD_Id)
                            @Html.HiddenFor(m => m.EMP_Id)

                            <div class="row">
                                <div class="col-md-12 form-group">
                                    <div class="col-md-3">Select File:</div>
                                    <div class="col-md-9">
                                        @Html.TextBoxFor(m => m.employee_Document.EMD_Document, new { @type = "file", @class = "form-control" })
                                        @Html.ValidationMessageFor(x => x.employee_Document.EMD_Document, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12 form-group">
                                    <div class="col-md-3">Choose Type:</div>
                                    <div class="col-md-9">
                                        @Html.DropDownListFor(m => m.employee_Document.DOT_Id, new SelectList(ViewBag.DocumentTypes, "DOT_Id", "DOT_Title"), "Select Type", new { @class = "form-control" })
                                        @Html.ValidationMessageFor(x => x.employee_Document.DOT_Id, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-12 m-t-20 text-right">
                                    <input class="btn btn-primary" type="submit" value="Upload Document" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="table-responsive">
                            <table class="table table-striped custom-table m-b-0">
                                <thead>
                                    <tr>
                                        <th>Document Type</th>
                                        <th>Title</th>
                                        <th>Download</th>
                                        <th>Delete</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.employee_Documents != null && Model.employee_Documents.Count() > 0)
                                    {
                                        @inject IConfiguration _configuration;
                                        string DocumentPath = _configuration.GetSection("DEFAULT_URL").Value + "/" + _configuration.GetSection("EMPLOYEE_DOCUMENT_PATH").Value;

                                        @foreach (var item in Model.employee_Documents)
                                        {
                                            string path = DocumentPath + "/" + item.EMD_Id + "/" + item.EMD_Name;
                                            <tr>
                                                <td>@item.DOT_.DOT_Title</td>
                                                <td>@item.EMD_Name </td>
                                                <td><a href='@Url.Action("DownloadDocument","Employees",new { EMD_Id=item.EMD_Id})' title="Download"><i class="fa fa-download m-r-5"></i> Download</a></td>
                                                <td><a href='@Url.Action("DeleteDocument","Employees",new { EMD_Id=item.EMD_Id})' title="Delete" onclick="return confirm('Are you sure?');"><i class="fa fa-trash m-r-5"></i> Delete</a></td>
                                            </tr>
                                        }
                                    }


                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="EmployeeAdvance" class="tab-pane fade">
        <div>
            <div class="content container-fluid">
                <div class="row">
                    <div class="col-sm-8">

                    </div>
                    <div class="col-sm-4 text-right m-b-30">
                        <a class="btn btn-primary rounded" href="@Url.Action("AddEditAdvance","Employees", new { EMP_Id = Model.EMP_Id})"><i class="fa fa-plus"></i> Add New Advance</a>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-8">
                        <div class="table-responsive">
                            <table class="table table-striped custom-table m-b-0">
                                <thead>
                                    <tr>
                                        <th>Amount Taken</th>
                                        <th>On</th>
                                        <th></th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.advances != null && Model.advances.Count() > 0)
                                    {
                                        @foreach (var item in Model.advances)
                                        {
                                            <tr>
                                                <td>@item.ADV_Amount </td>
                                                <td>@DateHelper.getDateWithFormat(@item.ADV_RegisteredOn) </td>
                                                <td><a href='@Url.Action("AddEditAdvance","Employees",new { ADV_Id=item.ADV_Id, EMP_Id = Model.EMP_Id})' title="Edit"><i class="fa fa-pencil m-r-5"></i> Edit Amount</a></td>
                                                <td><a href='@Url.Action("DeleteAdvance","Employees",new { ADV_Id=item.ADV_Id, EMP_Id = Model.EMP_Id})' title="Delete" onclick="return confirm('Are you sure?');"><i class="fa fa-trash m-r-5"></i> Remove</a></td>
                                            </tr>
                                        }
                                    }


                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
