    ViewData["Title"] = "Add-Edit Employee";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

@section Breadcrumbs{
    <li class="breadcrumb-item">@Html.ActionLink("Employees", "Index", "Employees")</li>
    <li class="breadcrumb-item">Employee Info</li>
}
@section scripts{
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>

    @*<link rel="stylesheet" href="//code.jquery.com/ui/1.11.4/themes/smoothness/jquery-ui.css">
        <script src="//code.jquery.com/jquery-1.10.2.js"></script>
        <script src="//code.jquery.com/ui/1.11.4/jquery-ui.js"></script>*@
    <script>
        $(document).ready(function () {
            //$('.selectpicker').selectpicker({
            //    liveSearch: true,
            //    showSubtext: true
            //});

            var items = "<option value='0'>Select City</option>";
            $("#EMP_City").html(items);
            if (@Model.EMP_City != null && @Model.EMP_City!= 0) {
                GetCity(@Model.EMP_City,@Model.EMP_State);
            }

            if (@Model.EMP_Payment_Type== 0) {
                $(".divBankType").show();
            } else {
                $(".divBankType").hide();
            }

            EMP_Id = $('#EMP_Id').val();
            if (EMP_Id == 0) {
                $('.nav li').not('.active').addClass('disabled');
                $('.nav li').not('.active').find('a').removeAttr("data-toggle");
            } else {
                $('.nav li').not('.active').removeClass('disabled');
            }
            var tab = GetParameterValues('tab');
            var EMP_Id = GetParameterValues('EMP_Id');
            if (tab == "View") {
                $('select', 'form').attr('disabled', true).attr('readonly', true);
                $('input', 'form').attr('disabled', true).attr('readonly', true);
            }
            if (tab == "AddEditAdvance") {
                var CurrentActive = $('.nav li.active').find("a").attr("href");
                var NextActive = $('.nav li.active').next('li').next('li').find("a").attr("href");
                $('.nav li.active').next('li').next('li').addClass("active");
                $('.nav li.active').prev('li').removeClass("active");
                $(CurrentActive).removeClass("in active");
                $(NextActive).addClass("in active");
            }
            if (tab == "AddEditDocuments") {
                var CurrentActive = $('.nav li.active').find("a").attr("href");
                var NextActive = $('.nav li.active').next('li').find("a").attr("href");
                $('.nav li.active').next('li').addClass("active");
                $('.nav li.active').prev('li').removeClass("active");
                $(CurrentActive).removeClass("in active");
                $(NextActive).addClass("in active");
            }

        });
        function GetParameterValues(param) {
            var url = window.location.href.slice(window.location.href.indexOf('?') + 1).split('&');
            for (var i = 0; i < url.length; i++) {
                var urlparam = url[i].split('=');
                if (urlparam[0] == param) {
                    return urlparam[1];
                }
            }
        };

        function PAYMENT_TYPE(payment) {
            if (payment.value == "0") { //Bank Account
                $(".divBankType").show();
            } else {
                $(".divBankType").hide();
            }
        };
        function PAYMENT_BANK_TYPE(bankType) {
            if (bankType.value == "0") { //IDBI BANK  Account
                $("#EMP_Bank").val("IDBI BANK");
                $("#EMP_Bank").prop("disabled", true);
            } else {
                $("#EMP_Bank").val("");
                $("#EMP_Bank").prop("disabled", false);
            }
        };
        $("#EMP_State").change(function () {
            
            var items = "<option value='0'>Select City</option>";
            $("#EMP_City").html(items);
            GetCity();
        });

        function GetCity(EMP_City, EMP_State) {
                        if (EMP_City != 0 && EMP_City != undefined) {
                if (@Model.EMP_City != 0) {
                    var EMP_City =@Model.EMP_City;
                } else {
                    var EMP_City = $("#EMP_City").val();
                }
                if (@Model.EMP_State != 0) {
                    var STA_Id =@Model.EMP_State;
                } else {
                    var STA_Id = $("#EMP_State").val();
                }
            } else if (EMP_State == undefined) {
                var STA_Id = $("#EMP_State").val();
            }

            var url = "/Employees/GetCity";

            $.getJSON(url, { STA_Id: STA_Id }, function (data) {
                var item = "";
                $("#EMP_City").empty();
                $.each(data, function (i, city) {
                    var select = "";
                    if (EMP_City == city.value) {
                        select = "selected='selected'";
                    }
                    item += "<option " + select + " value='" + city.value + "'>" + city.text + "</option>";
                });
                $("#EMP_City").html(item);
            });
        };

    </script>
    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {
            alert('@TempData["message"]');
        });
        </script>
    };

}

