@model List<RMERP.DAL.ViewModel.InvoiceVM>
@using static RMERP.DAL.Helpers.ProjectUtils;
@using RMERP.Helpers

<div class="row">
    <div class="col-md-12">
        @if (Model.Count() > 0)
        {
            <div class="table-responsive">
                <table class="invoiceTable table table-striped custom-table m-b-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Invoice Date</th>
                            <th>Invoice Number</th>
                            <th>Client</th>
                            <th>Amount</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{int srNo = 1;}
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@srNo</td>
                                <td>@DateHelper.getLongDateFormat(item.INV_Date)</td>
                                <td><a target="_blank" href="@Url.Action("DownloadInvoice","Invoices",new {INV_Id=item.INV_Id,ActionId= (int)PDFAction.View })">INV_@item.INV_Number</a></td>
                               
                                @*<td><a data-internalid="-1">INV_@item.INV_Number</a></td>*@

                                <td>@item.CLI_.CLI_Name (@item.FRM_.FRM_ShortName)</td>
                                <td><i class="fa fa-rupee"></i> @item.INV_Total</td>

                                <td class="text-right">

                                    <a href="@Url.Action("AddEditInvoice","Invoices",new {INV_Id=item.INV_Id})"><i class="fa fa-pencil m-r-5"></i> Edit |</a>
                                    <a href="@Url.Action("DownloadInvoice","Invoices",new {INV_Id=item.INV_Id,Action= (int)PDFAction.Download })"><i class="fa fa-file-pdf-o m-r-5"></i> Download |</a>
                                    <a href="@Url.Action("DeleteInvoice","Invoices",new {INV_Id=item.INV_Id })"><i class="fa fa-trash-o m-r-5"></i> Delete</a>
                                                                       
                                </td>
                            </tr>
                            srNo++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p>No Invoice Generated.</p>
        }

    </div>
</div>