@model RMERP.DAL.ViewModel.InvoiceVM
@{
    ViewData["Title"] = "Invoice Info";
}
@section Breadcrumbs{
    <li class="breadcrumb-item">@Html.ActionLink("Invoices", "Index", "Invoices")</li>
    <li class="breadcrumb-item">Invoice Info</li>
}
<style>
    .modal-dialog {
        padding-top: 50px;
    }
</style>
<div class="row">
    <div class="col-sm-8">
        <h4 class="page-title">Create Invoice</h4>
    </div>
</div>
<div class="row">
    <div class="col-md-12">
        <form>
            <div class="row">
                <div class="col-sm-8">
                    <div class="form-group">
                        @Html.HiddenFor(m => m.INV_Id)
                        @Html.HiddenFor(m => m.INV_CreatedOn)
                        @Html.LabelFor(m => m.CLI_Id, new { @class = "control-label" })
                        @Html.DropDownListFor(m => m.CLI_Id, new SelectList(ViewBag.Clients, "CLI_Id", "CLI_Name"), "Select Client", new { @class = "select floating" })
                        @Html.ValidationMessageFor(m => m.CLI_Id, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="col-sm-2">
                </div>
                <div class="col-sm-2">
                    <div class="form-group">
                        @Html.LabelFor(m => m.INV_ClientOrder_Number, new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.INV_ClientOrder_Number, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.INV_ClientOrder_Number, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="form-group">
                        @Html.LabelFor(m => m.INV_Number, new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.INV_Number, new { @readonly = "readonly", @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.INV_Number, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="col-sm-4">
                    <div class="form-group">
                        @Html.LabelFor(m => m.INV_Date, new { @class = "control-label" })
                        @Html.EditorFor(m => m.INV_Date, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(m => m.INV_Date, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="col-sm-2">
                </div>
                <div class="col-sm-2">
                    <div class="form-group">
                        @Html.LabelFor(m => m.INV_ClientOrder_Date, new { @class = "control-label" })
                        @Html.EditorFor(m => m.INV_ClientOrder_Date, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(m => m.INV_ClientOrder_Date, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>
            <img id="loading-image" src="~/assets/img/25.gif" style="display:none; position: fixed;left: 50%;top: 31%;z-index: 1000000; background-position:center;" />
            <div class="row">
                <div class="col-md-12 col-sm-12 col-xs-12">
                    <div class="table-responsive">
                        <table class="table table-hover table-white" id="tblIncidenceConcepts">
                            <thead>
                                <tr>
                                    <th style="width: 20px">#</th>
                                    <th class="col-md-6">Description</th>
                                    <th>Amount</th>
                                    <th> </th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int sr = 1;
                                }
                                @foreach (var item in Model.Invoice_Concepts)
                                {
                                    <tr>
                                        <td style="width: 5%">
                                            <input class="form-control" id="INC_Serial_Number" value=@item.INC_Serial_Number type="text" style="min-width:50px">
                                        </td>
                                        <td style="width: 65%">
                                            <textarea id="INC_Description" class="form-control desc">@item.INC_Description</textarea>
                                        </td>
                                        <td style="width: 20%">
                                            <input class="form-control calculation" id="INC_Total" value="@item.INC_Total" type="text" style="max-width:150px">
                                        </td>
                                        <td style="width: 10%">
                                            <a onclick="RemoveInvoiceConcept(this)" class="text-danger font-18" title="Remove"><i class="fa fa-trash-o" aria-hidden="true"></i></a>
                                        </td>
                                    </tr>
                                    sr++;
                                }

                            </tbody>
                            <tfoot>
                                <tr>
                                    <td style="width: 5%">
                                        <input class="form-control" id="INC_Serial_Number_nxt" value=@sr type="text" style="min-width:50px">
                                    </td>
                                    <td style="width: 65%">
                                        <textarea id="INC_Description" class="form-control desc"></textarea>
                                    </td>
                                    <td style="width: 20%">
                                        <input class="form-control calculation" id="INC_Total" type="text" style="max-width:150px">

                                    </td>
                                    <td style="width: 10%">
                                        <a class="InvoiceType text-success font-18" title="Add" id="opnInvoice"><i class="fa fa-plus"></i></a>
                                    </td>

                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover table-white border">
                            <tbody>
                                <tr>
                                    <td style="width: 5%"></td>
                                    <td style="width: 65%" class="text-right">
                                        Total
                                    </td>
                                    <td style="width: 10%">
                                        @Html.TextBoxFor(m => m.All_INC_Total, new { @class = "form-control text-right", @readonly = "readonly", style = "max-width:150px" })
                                    </td>
                                    <td style="width: 10%"></td>
                                    <td style="width: 10%"></td>
                                </tr>
                                <tr>
                                    <td style="width: 5%"></td>
                                    <td style="width: 65%" class="text-right">
                                        CGST(%)
                                    </td>
                                    <td style="width: 10%">
                                        @Html.TextBoxFor(M => M.INV_CGST_Percentage, new { @class = "form-control text-right", style = "max-width:150px", onfocusout = "calculateGST()" })
                                    </td>
                                    <td style="width: 10%" class="text-right"> Total CGST</td>
                                    <td style="width: 10%">
                                        @Html.TextBoxFor(M => M.INV_CGST_Total, new { @class = "form-control text-right", @readonly = "readonly", style = "max-width:150px" })
                                    </td>

                                </tr>
                                <tr>
                                    <td style="width: 5%"></td>
                                    <td style="width: 65%" class="text-right">
                                        SGST(%)
                                    </td>
                                    <td style="width: 10%">
                                        @Html.TextBoxFor(M => M.INV_SGST_Percentage, new { @class = "form-control text-right", style = "max-width:150px", onfocusout = "calculateGST()" })
                                    </td>
                                    <td style="width: 10%" class="text-right"> Total SGST</td>
                                    <td style="width: 10%">
                                        @Html.TextBoxFor(M => M.INV_SGST_Total, new { @class = "form-control text-right", @readonly = "readonly", style = "max-width:150px" })
                                    </td>

                                </tr>
                                <tr>
                                    <td style="width: 5%"></td>
                                    <td style="width: 65%" class="text-right">
                                        IGST(%)
                                    </td>
                                    <td style="width: 10%">
                                        @Html.TextBoxFor(M => M.INV_IGST_Percentage, new { @class = "form-control text-right", style = "max-width:150px", onfocusout = "calculateGST()" })
                                    </td>
                                    <td style="width: 10%" class="text-right"> Total IGST</td>
                                    <td style="width: 10%">
                                        @Html.TextBoxFor(M => M.INV_IGST_Total, new { @class = "form-control text-right", @readonly = "readonly", style = "max-width:150px" })
                                    </td>

                                </tr>
                                <tr>
                                    <td style="width: 5%"></td>
                                    <td style="width: 65%" class="text-right"></td>
                                    <td style="width: 10%"></td>
                                    <td style="width: 10%" class="text-right">Tax</td>
                                    <td style="width: 10%">
                                        @Html.TextBoxFor(m => m.totTAX, new { @class = " form-control text-right", @readonly = "readonly" })
                                    </td>
                                </tr>
                                <tr>
                                    <td style="width: 5%"></td>
                                    <td style="width: 65%" class="text-right"></td>
                                    <td style="width: 10%"></td>
                                    <td style="width: 10%" class="text-right"> Grand Total &nbsp;(<i class="fa fa-rupee"></i>)</td>
                                    <td style="width: 10%">
                                        @Html.TextBoxFor(m => Model.INV_Total, new { @class = "form-control text-right", @readonly = "readonly" })
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        <label>Remarks</label>
                        @Html.TextAreaFor(m => m.INV_Remark, new { @class = " form-control" })
                    </div>
                </div>
            </div>
            <button class="btn btn-primary" id="btnSave">Save All</button>
        </form>
    </div>
</div>
<div id="invoiceTemplate">
</div>

@section scripts{
    <script type="text/javascript" src="http://ajax.cdnjs.com/ajax/libs/json2/20110223/json2.js"></script>
    <script src="https://cdn.ckeditor.com/ckeditor5/12.4.0/classic/ckeditor.js"></script>

    <script src="http://ajax.googleapis.com/ajax/libs/jquery/1.8.3/jquery.min.js" type="text/javascript"></script>
   @*<link href="http://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.0.3/css/bootstrap.min.css" rel="stylesheet" type="text/css" />*@
    <script src="http://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.0.3/js/bootstrap.min.js" type="text/javascript"></script>
    @*<link href="http://cdn.rawgit.com/davidstutz/bootstrap-multiselect/master/dist/css/bootstrap-multiselect.css" rel="stylesheet" type="text/css" />*@
    <script src="http://cdn.rawgit.com/davidstutz/bootstrap-multiselect/master/dist/js/bootstrap-multiselect.js" type="text/javascript"></script>


    <script type="text/javascript">
        var j = jQuery.noConflict();
        j(function () {
            j('#Left_EMP_Id').multiselect({
                includeSelectAllOption: true
            });
        });
    </script>


    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {
            alert('@TempData["message"]');
        });
        </script>
    };
    <script>
        $(document).ready(function () {                   

            var allEditors = document.querySelectorAll('.desc');
            for (var i = 0; i < allEditors.length; ++i) {
                ClassicEditor.create(allEditors[i]);
            };
            $(document).on('change', '.calculation', function () {
                var All_INC_Total = 0;
                $("#tblIncidenceConcepts TBODY TR").each(function () {
                    var row = $(this);
                    var INC_Total = parseFloat(row.find("TD").eq(2).children().val());
                    All_INC_Total = All_INC_Total + parseFloat(INC_Total);
                });
                $("#All_INC_Total").val(All_INC_Total);
                calculateGST();
            });

            $(document).on("change", "SELECT[class^=Month_0]", function (event) {               
                var WAG_Id = $("#month_0").val();
                var CLI_Id = $("#CLI_Id").val();
                $(".drpType").empty();
                GetRequirenmentTypes(WAG_Id, CLI_Id);
                return false;
            });


        });
        function GetRequirenmentTypes(WAG_Id, CLI_Id) {
            debugger;
            var Url = siteUrl + "Invoices/GetRequirenmentTypes?Wag_Id=" + WAG_Id + "&CLI_Id=" + CLI_Id;
            $.ajax({
                type: 'POST',
                url: Url,
                dataType: 'json',
                success: function (Types) {
                    debugger;
                    $.each(Types, function (i, Type) {
                        $(".drpType").append('<option value="' + Type.value + '">' +
                            Type.text + '</option>');
                    });
                },
                error: function (ex) {
                    alert('Failed to retrieve Type.' + ex);
                }
            });
        };
        var DELAY = 700,
            clicks = 0,
            timer = null;
        $("#opnInvoice").click(function () {
            if ($("#CLI_Id").val() != "") {
                clicks++;  //count clicks
                if (clicks === 1) {
                    timer = setTimeout(function () {
                        openInvoiceTemplate(); //perform single-click action
                        clicks = 0;             //after action performed, reset counter

                    }, DELAY);

                } else {
                    clearTimeout(timer);    //prevent single-click action //perform double-click action
                    clicks = 0;             //after action performed, reset counter
                }
            } else {
                alert("Select client first!");
            }
        });

        function openInvoiceTemplate() {
            $(".modal-backdrop").removeClass("modal-backdrop").addClass("modal");
            var CLI_Id = $("#CLI_Id").val();
            var INV_Date = $("#INV_Date").val();
            var Url = siteUrl + "Invoices/GetInvoiceTemplate?CLI_Id=" + CLI_Id + "&INV_Date=" + INV_Date;
            $.ajax({
                type: "GET",
                url: Url,
                beforeSend: function () {
                    $("#loading-image").show();
                    $('#invoiceTemplate').html("");
                    $('#InvoiceTypeModal').hide();
                },
                success: function (data) {
                    debugger;
                    $('#invoiceTemplate').html(data);
                    $("#loading-image").hide();
                    //var items = "<option value='0'>Select Type</option>";
                    //var WAG_Id = $("#WAG_Id").val();
                    //var CLI_Id = $("#CLI_Id").val();
                    //$(".drpType").html(items);
                    //if (WAG_Id != "0" || WAG_Id != "" || typeof WAG_Id != 'undefined') {
                    //    GetRequirenmentTypes(WAG_Id, CLI_Id);
                    //    return false;
                    //}
                    $('#InvoiceTypeModal').modal('show');
                }
            })
        };

       
        function FillData(id) {           
            var EMPs = "";
            var Type_Id = 0;
            var WAG_Id = $("#month_" + id).val();
            var CLI_Id = $("#CLI_Id").val();
            var Type = $("#type_id_" + id).val();

            if (id == 0) {
                Type_Id = $("#type_" + id).val();
                WAG_Id = $("#month_" + id).val();
            }
            if (id == 1) {
                WAG_Id = $("#month1_" + id).val();
            }
            if (id == 2) {
                WAG_Id = $("#month2_" + id).val();
            }
            if (id == 3) {
                var selected = $("#Left_EMP_Id option:selected");
                
                selected.each(function () {                
                    EMPs += $(this).val() + ",";
                });
                EMPs= EMPs.substring(0, EMPs.length - 1) 
                              
            }            
            if (CLI_Id != "") {
                var Url = siteUrl + "Invoices/GetInvoiceData?CLI_Id=" + CLI_Id + "&Type_Id=" + Type_Id + "&WAG_Id=" + WAG_Id + "&Type=" + Type + "&EMPs=" + EMPs;
                $.ajax({
                    type: "GET",
                    url: Url,
                    success: function (data) {
                        //Get the reference of the Table's TBODY element.
                        var tBody = $("#tblIncidenceConcepts > TBODY")[0];
                        var id = $('#tblIncidenceConcepts  tr').length - 1;
                        //Add Row.
                        var row = tBody.insertRow(-1);
                        cell = $(row.insertCell(-1));
                        cell.html("<input class='form-control' value=" + id + " type='text'>");


                        //Add Description cell.
                        cell = $(row.insertCell(-1));
                        //cell.html("<p id='desc'>" + data.inC_Description + "</p>");
                        var newDesc = "newDesc_" + id;
                        var textArea = $('<textarea id="INC_Description" class="form-control desc ' + newDesc + '"/>');
                        textArea.text(data.inC_Description);
                        cell.append(textArea);

                        var allEditors = document.querySelectorAll('.' + newDesc);
                        for (var i = 0; i < allEditors.length; ++i) {
                            ClassicEditor.create(allEditors[i]);
                        }


                        //Add Total cell.
                        cell = $(row.insertCell(-1));
                        cell.html(data.inC_Total);
                        var clClass = "calc_" + id;
                        cell.html('<input class="form-control calculation ' + clClass + '" id="INC_Total" value="' + data.inC_Total + '" type="text" style="max-width:150px"> ');

                        cell = $(row.insertCell(-1));

                        var stringRemove = "<a onclick=\"RemoveInvoiceConcept(this)\" class=\"text-danger font-18\" title=\"Remove\">";
                        stringRemove = stringRemove + "<i class=\"fa fa-trash-o\" aria-hidden=\"true\"> ";
                        stringRemove = stringRemove + "</i ></a > ";
                        cell.append(stringRemove);

                        var v = parseFloat($("#All_INC_Total").val());
                        var All_INC_Total = (isNaN(All_INC_Total = parseFloat($("#All_INC_Total").val(), 10)) ? 0 : All_INC_Total);
                        $("#All_INC_Total").val(parseFloat(All_INC_Total) + data.inC_Total);

                        calculateGST();

                        //Clear the TextBoxes.
                        var Next_INC_Serial_Number = parseInt(id) + 1;
                        $("#INC_Serial_Number_nxt").val(Next_INC_Serial_Number);

                        $('#InvoiceTypeModal').modal('toggle');
                    }
                })
            } else {
                alert("Please select client!");
            }

        };

        function calculateGST() {
            var INV_CGST_Percentage = (isNaN(INV_CGST_Percentage = parseFloat($("#INV_CGST_Percentage").val(), 10)) ? 0 : INV_CGST_Percentage);
            var INV_SGST_Percentage = (isNaN(INV_SGST_Percentage = parseFloat($("#INV_SGST_Percentage").val(), 10)) ? 0 : INV_SGST_Percentage);
            var INV_IGST_Percentage = (isNaN(INV_IGST_Percentage = parseFloat($("#INV_IGST_Percentage").val(), 10)) ? 0 : INV_IGST_Percentage);
            var All_INC_Total = $("#All_INC_Total").val();

            var INV_CGST_Total = (parseFloat(All_INC_Total) * parseFloat(INV_CGST_Percentage)) / 100;
            var INV_SGST_Total = (parseFloat(All_INC_Total) * parseFloat(INV_SGST_Percentage)) / 100;
            var INV_IGST_Total = (parseFloat(All_INC_Total) * parseFloat(INV_IGST_Percentage)) / 100;

            $("#INV_CGST_Total").val(INV_CGST_Total.toFixed(2));
            $("#INV_SGST_Total").val(INV_SGST_Total.toFixed(2));
            $("#INV_IGST_Total").val(INV_IGST_Total.toFixed(2));

            var totTAX = parseFloat(INV_CGST_Total) + parseFloat(INV_SGST_Total) + parseFloat(INV_IGST_Total);
            $("#totTAX").val(totTAX.toFixed(2));

            $("#INV_Total").val((parseFloat(All_INC_Total) + parseFloat(totTAX)).toFixed(2));
        };

        function RemoveInvoiceConcept(button) {
            var row = $(button).closest("TR");
            var INC_Total = $.trim($("TD", row).eq(2).children().val());
            if (confirm("Are you sure you want to Remove?")) {
                var table = $("#tblIncidenceConcepts")[0];
                table.deleteRow(row[0].rowIndex);
            }

            var All_INC_Total = (isNaN(All_INC_Total = parseFloat($("#All_INC_Total").val(), 10)) ? 0 : All_INC_Total);
            $("#All_INC_Total").val((parseFloat(All_INC_Total) - parseFloat(INC_Total)).toFixed(2));
            calculateGST();
        };
        $("body").on("click", "#btnSave", function () {

            //Loop through the Table rows and build a JSON array.
            var InvoiceVM = {};
            InvoiceVM.INV_Id = parseInt($("#INV_Id").val());
            InvoiceVM.FRM_Id = 0;
            InvoiceVM.CLI_Id = parseInt($("#CLI_Id").val());
            InvoiceVM.INV_Number = $("#INV_Number").val();
            InvoiceVM.INV_Date = $("#INV_Date").val();
            InvoiceVM.INV_Remark = ($("#INV_Remark") != "" ? $("#INV_Remark").val() : null);
            InvoiceVM.INV_ClientOrder_Number = (isNaN(INV_ClientOrder_Number = parseFloat($("#INV_ClientOrder_Number").val(), 10)) ? 0 : INV_ClientOrder_Number);

            InvoiceVM.INV_ClientOrder_Date = ($("#INV_ClientOrder_Date") == "0001-01-01" ? null : $("#INV_ClientOrder_Date").val());
            InvoiceVM.INV_CreatedOn = $("#INV_CreatedOn").val();

            InvoiceVM.INV_HSN = (isNaN(INV_HSN = parseFloat($("#INV_HSN").val(), 10)) ? 0 : INV_HSN);
            InvoiceVM.INV_Total = (isNaN(INV_Total = parseFloat($("#INV_Total").val(), 10)) ? 0 : INV_Total);

            InvoiceVM.INV_CGST_Percentage = (isNaN(INV_CGST_Percentage = parseFloat($("#INV_CGST_Percentage").val(), 10)) ? 0 : INV_CGST_Percentage);
            InvoiceVM.INV_SGST_Percentage = (isNaN(INV_SGST_Percentage = parseFloat($("#INV_SGST_Percentage").val(), 10)) ? 0 : INV_SGST_Percentage);
            InvoiceVM.INV_IGST_Percentage = (isNaN(INV_IGST_Percentage = parseFloat($("#INV_IGST_Percentage").val(), 10)) ? 0 : INV_IGST_Percentage);

            InvoiceVM.INV_CGST_Total = (isNaN(INV_CGST_Total = parseFloat($("#INV_CGST_Total").val(), 10)) ? 0 : INV_CGST_Total);
            InvoiceVM.INV_SGST_Total = (isNaN(INV_SGST_Total = parseFloat($("#INV_SGST_Total").val(), 10)) ? 0 : INV_SGST_Total);
            InvoiceVM.INV_IGST_Total = (isNaN(INV_IGST_Total = parseFloat($("#INV_IGST_Total").val(), 10)) ? 0 : INV_IGST_Total);

            var Concepts = new Array();

            $("#tblIncidenceConcepts TBODY TR").each(function () {

                var row = $(this);
                var Concept = {};
                Concept.INC_Serial_Number = parseInt(row.find("TD").eq(0).children().val());
                Concept.INC_Description = $.trim(row.find("TD").eq(1).find(".ck-editor__editable_inline").html());
                Concept.INC_Total = parseFloat(row.find("TD").eq(2).children().val());
                Concepts.push(Concept);
            });
            InvoiceVM.Invoice_Concepts = Concepts;
            $.ajax({
                url: siteUrl + 'Invoices/AddEditInvoice',
                contentType: "application/json",
                async: true,
                type: "POST",
                data: JSON.stringify(InvoiceVM),
                success: function (data, textStatus, jQxhr) {
                    if (data == "Ok") {
                        window.location.href = siteUrl + "Invoices/Index";
                    } else {
                        alert("Try Again");
                    }
                }, error: function (jqXhr, textStatus, errorThrown) {
                    alert("error");
                }
            });
        });

    </script>
}