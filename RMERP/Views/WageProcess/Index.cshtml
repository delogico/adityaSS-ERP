@model IEnumerable<RMERP.DAL.Models.WageProcess>

@{
    ViewData["Title"] = "Wage Process";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

@section scripts{
    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {               
                alert('@TempData["message"]');
                WageProcessList();
        });
        </script>
    };
    <script>

        function onConfirmClick() {
            $.ajax({
                type: "GET",
                url: "/WageProcess/nextWageMonth/",
                success: function (data) {
                    bootbox.confirm({
                        title: "Confirmation",
                        message: "Are you sure want to create wage for " + data+"?",
                        buttons: {
                            confirm: {
                                label: 'Yes',
                                className: 'btn-success'
                            },
                            cancel: {
                                label: 'No',
                                className: 'btn-danger'
                            }
                        },
                        callback: function (result) {
                            if (result == true) {
                                $.ajax({
                                    type: "GET",
                                    url: "/WageProcess/CreateNextMonthWage/",
                                    success: function (data) {
                                        WageProcessList();
                                    }
                                })
                            }
                            else if (result == false) {
                            }
                        }
                    });
                }
            })
        };
        
        function WageProcessList() {
            $.ajax({
                type: "GET",
                url: "/WageProcess/WageProcessList/",
                success: function (data) {
                    $('#WageProcessList').html(data);
                }
            })          
        };
    </script>
}
<style>
    .modal-dialog {
        transform: translate(0, -50%);
        top: 30%;
        margin: 0 auto;
    }
</style>
<div>
    <div class="content container-fluid">
        <div class="row">
            <div class="col-sm-8">
                <h4 class="page-title">@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-4 text-right m-b-30">
                @*<a class="btn btn-primary rounded" href='@Url.Action("CreateNextMonthWage","WageProcess")' onclick="return confirm('Are you sure you want to create?');"><i class="fa fa-plus"></i> Create @ViewBag.month Month</a>*@

                <button  id="buttonID" onclick="onConfirmClick()" class="btn btn-primary rounded"><i class="fa fa-plus"></i> Create next month</button>
            </div>
        </div>

        <div id="WageProcessList">
            @{Html.RenderPartial("_WageProcessList", Model);}
        </div>
    </div>
</div>


