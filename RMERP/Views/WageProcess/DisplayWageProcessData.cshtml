@model IEnumerable<RMERP.DAL.ViewModel.DisplayExcel>
@{
    ViewData["Title"] = "Display Wage Process Data";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}

@if (Model.Count()<1)
{
    <h4>No data to display</h4>
}
else
{
<div class="modal-dialog modelLeftSide">
    <button type="button" class="close" data-dismiss="modal">&times;</button>
    <div class="modal-content modal-lg">
        <div class="modal-header">
            <h4 class="modal-title">Summary Of Attendance Template</h4>
            <h6 class="modal-title">Total Employee= @ViewBag.totEmp</h6>
        </div>
        <div class="modal-body">
            <div>
                <div class="content container-fluid">

                    <div class="row">
                        <div class="col-md-12">
                            <div>
                                <table class="table table-hover custom-table m-b-0">
                                    <thead>
                                        <tr>
                                            <td><b>Employee Name</b></td>
                                            <td><b>Designation</b></td>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@item.EmpName</td>
                                                <td>@item.DesName</td>
                                            </tr>
                                        }

                                    </tbody>
                                </table>
                            </div>
                            <div class="m-t-20 text-center">
                                <input type="submit" value="Export To Database" name="Export" id="btnSubmit" class="btn btn-success" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
}

