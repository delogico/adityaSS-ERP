@model RMERP.DAL.ViewModel.UploadPageViewModel
@using static RMERP.DAL.App_Code.ProjectUtils;

@{
    ViewData["Title"] = "UploadPage";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}


<div class="modal-dialog">
    <button type="button" class="close" data-dismiss="modal">&times;</button>
    <div class="modal-content modal-lg">
        <div class="modal-header">
            <h4 class="modal-title">Upload Attendance Template</h4>
        </div>
        <div class="modal-body">
            @using (Html.BeginForm("ImportWageProcessData", "WageProcess", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        Wage Process : 
                        <label> @Model.WageMonth</label>
                        @Html.HiddenFor(m => m.WageId)
                        @Html.HiddenFor(m => m.WageMonth)
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="form-group">
                        Client Name : <b>@Model.ClientName</b>
                        <label> @Model.ClientName</label>
                        @Html.HiddenFor(m => m.ClientId)
                        @Html.HiddenFor(m => m.ClientName)
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                       Choose Template : 
                        <label class="radio-inline form-control">
                            @foreach (var Execl_BasicShifts in Enum.GetValues(typeof(Execl_BasicShifts)))
                            {
                                <label class="radio-inline">
                                    <b>@Html.RadioButtonFor(s => s.TemplateName, (int)Execl_BasicShifts, (int)Execl_BasicShifts == 0 ? (object)new { @checked = true, @id = (int)Execl_BasicShifts } : new { @id = (int)Execl_BasicShifts })@Execl_BasicShifts</b>
                                </label>
                            }
                        </label>
                        @Html.ValidationMessageFor(x => x.TemplateName, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>
            <div class="form-group">
               Choose File : 
                @Html.TextBoxFor(m => m.TemplateFile, new { @type="file",@class="form-control"})
            </div>
            <div class="m-t-20 text-center">
                <input class="btn btn-primary" type="submit" value="View Of Attendance Template" />
            </div>
            }
        </div>
    </div>
</div>


