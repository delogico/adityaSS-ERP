@model RMERP.DAL.ViewModel.UploadPageViewModel
@using static RMERP.DAL.App_Code.ProjectUtils;

@{
    ViewData["Title"] = "UploadPage";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}


<div class="modal-dialog">
    <button type="button" class="close" data-dismiss="modal">&times;</button>
    <div class="modal-content modal-lg">
        <div class="modal-header">
            <h4 class="modal-title">Upload Page</h4>
        </div>
        <div class="modal-body">
            @using (Html.BeginForm("UploadPage", "WageProcess", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        <label>Wage Process</label> @Model.WageMonth
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="form-group">
                        <label>Client Name </label> @Model.ClientName
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        @Html.Label("Choose Template")
                        <label class="radio-inline form-control ">
                            @foreach (var Execl_BasicShifts in Enum.GetValues(typeof(Execl_BasicShifts)))
                            {
                                <label class="radio-inline">
                                    @Html.RadioButtonFor(s => s.TemplateName, (int)Execl_BasicShifts, (int)Execl_BasicShifts == 1 ? (object)new { @checked = true, @id = (int)Execl_BasicShifts } : new { @id = (int)Execl_BasicShifts })@Execl_BasicShifts
                                </label>
                            }
                        </label>
                        @Html.ValidationMessageFor(x => x.TemplateName, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label>Choose File</label>
                @Html.TextBoxFor(m => m.TemplateName, new { @type="file"})
            </div>
            <div class="m-t-20 text-center">
                <input class="btn btn-primary" type="submit" value="Go" />
            </div>
            }
        </div>
    </div>
</div>


