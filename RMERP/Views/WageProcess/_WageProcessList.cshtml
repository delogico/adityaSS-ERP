@model RMERP.DAL.ViewModel.WageProcessVM

<div class="row wage_raw">
    <div class="col-md-2">
        <h4>@Model.WAG_Full_Month()</h4>
        Total Clients: @Model.ActiveClients
    </div>
    <div class="col-md-2">
        <h6>Attendance:</h6>
        <b>@Html.ActionLink("Attendance", "WageAttendanceList", "Attendance", new { WAG_Id = Model.WAG_Id })</b>
        <div style="font-size:10px;">
            @if (Model.ImportedClients() == Model.ActiveClients)
            {
                <span class="done" style="color:green;">Attendence Imported for all clients.</span>
            }
            else
            {
                <span style="color:orangered;">@Model.NotImportedClients() client's attendence Pending to import.</span>
            }
        </div>
    </div>
    <div class="col-md-2">
        <h6>Advance:</h6>
        <ul style="font-size:10px;padding-left: 10px !important;">
            <li>@Html.ActionLink("Advance Distribution Report(" + Model.totEmpTakeAdvance + ")", "AdvanceRptForBank", "Employees", new { WAG_Month = Model.WAG_Month, FRM_Id = Model.FRM_Id })</li>
            <li>@Html.ActionLink("Set installment against advance", "UpdateAdvanceEMI", "Employees", new { WAG_Month = Model.WAG_Month, WAG_Id = Model.WAG_Id, FRM_Id = Model.FRM_Id })</li>
        </ul>
    </div>
    <div class="col-md-2">
        <h6>Wage Register:</h6>
        <b>@Html.ActionLink("Wage Register", "WageRegister", "WageRegister", new { WAG_Id = Model.WAG_Id, FRM_Id = Model.FRM_Id })</b>
        <div style="font-size:10px;">

            @if (Model.WageStatus == true)
            {
                <span class="done" style="color:green;font-weight:bold;">Wage Register Finalized.</span>
            }
            else
            {
                @if (Model.WageRegisterSaved() == Model.ActiveClients)
                {
                    <span style="color:green;">Wage Register for all Clients is Finalize.</span><br />
                    <a class="btn btn-primary btn-xs" onclick="return window.confirm('Are you sure, you want to finalize wage Register for this month? Now onwards wage register can not be able to modify.')"
                       href='@Url.Action("WageRegisterStatus", "WageProcess", new { WAG_Id = Model.WAG_Id})' title="Confirm">
                        Finalize Web Register
                    </a>
                }
                else
                {
                    <span style="color:orangered;">@Model.WageRegisterNotSaved() client's Wage register Pending to finalize.</span>
                }

            }
        </div>
    </div>
    <div class="col-md-4">
        <h6>Reports:</h6>

        <div class="raw">
            <div class="col-md-4">
                <ul style="font-size:10px;padding-left: 10px !important;">
                    <li><a href='@Url.Action( "PFReportExcel","Reports",new { WAG_Id = Model.WAG_Id })' title="PF Report"><i class="fa fa-file-excel-o m-r-5"></i>PF Report.xlsx</a></li>
                    <li><a href='@Url.Action( "PFReportText","Reports",new { WAG_Id = Model.WAG_Id })' title="PF Report"><i class="fa fa-file-text-o m-r-5"></i>PF Report.txt</a></li>
                    <li><a href='@Url.Action( "ESICReportExcel","Reports",new { WAG_Id = Model.WAG_Id })' title="PF Report"><i class="fa fa-file-excel-o m-r-5"></i>ESIC Report.xlsx</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <ul style="font-size:10px;padding-left: 10px !important;">                    
                    <li><a href='@Url.Action( "MLWF_ContributionExcel","Reports",new { WAG_Id = Model.WAG_Id })' title="MLWF CONTRIBUTION Report"><i class="fa fa-file-excel-o m-r-5"></i>MLWF CONTRIBUTION Report.xlsx</a></li>
                    <li><a href='@Url.Action( "PayTaxExcel","Reports",new { WAG_Id = Model.WAG_Id })' title="PAY TAX Report"><i class="fa fa-file-excel-o m-r-5"></i>PAY TAX Report.xlsx</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <ul style="font-size:10px;padding-left: 10px !important;">
                    <li>
                        <div class="dropdown">
                            <a href="#" style="font-size:10px;color:#009ce7;" class="action-icon dropdown-toggle" data-toggle="dropdown" aria-expanded="false"><i class="fa fa-file-excel-o m-r-5"></i>Bank Reports</a>
                            <ul class="dropdown-menu pull-right">
                                <li><a style="font-size:10px;color:#009ce7;" href='@Url.Action( "NEFT_BankReportExcel","Reports",new { WAG_Id = Model.WAG_Id })' title="Company Wise Transfer Report"><i class="fa fa-file-excel-o m-r-5"></i>Company Wise Transfer Report.xlsx</a></li>
                                <li><a style="font-size:10px;color:#009ce7;" href='@Url.Action( "IDBI_To_IDBI_BankReportExcel","Reports",new { WAG_Id = Model.WAG_Id })' title="IDBI Bank To IDBI Bank Report"><i class="fa fa-file-excel-o m-r-5"></i>IDBI Bank To IDBI Bank Report.xlsx</a></li>
                                <li><a style="font-size:10px;color:#009ce7;" href='@Url.Action( "IDBI_To_Other_BankReportExcel","Reports",new { WAG_Id = Model.WAG_Id })' title="IDBI Bank To Others Report"><i class="fa fa-file-excel-o m-r-5"></i>IDBI Bank To Others Report.xlsx</a></li>
                                <li><a style="font-size:10px;color:#009ce7;" href='@Url.Action( "CHEQUE_CASH_BankReportExcel","Reports",new { WAG_Id = Model.WAG_Id })' title="CHEQUE/CASH Report"><i class="fa fa-file-excel-o m-r-5"></i>CHEQUE/CASH Report.xlsx</a></li>
                            </ul>
                        </div>
                    </li>
                </ul>
                <ul style="font-size:10px;padding-left: 10px !important;">
                    <li>
                        <div class="dropdown">
                            <a href="#" style="font-size:10px;color:#009ce7;" class="action-icon dropdown-toggle" data-toggle="dropdown" aria-expanded="false"><i class="fa fa-file-excel-o m-r-5"></i>Advance Reports</a>
                            <ul class="dropdown-menu pull-right">
                                <li><a style="font-size:10px;color:#009ce7;" href='@Url.Action( "IDBI_To_IDBI_AdvanceReportExcel","Reports",new { WAG_Id = Model.WAG_Id,FRM_Id=Model.FRM_Id })' title="IDBI To IDBI Advance Report"><i class="fa fa-file-excel-o m-r-5"></i>IDBI To IDBI Advance Report.xlsx</a></li>
                                <li><a style="font-size:10px;color:#009ce7;" href='@Url.Action( "IDBI_To_Other_AdvanceReportExcel","Reports",new { WAG_Id = Model.WAG_Id,FRM_Id=Model.FRM_Id })' title="IDBI To Others Advance Report"><i class="fa fa-file-excel-o m-r-5"></i>IDBI To Others Advance Report.xlsx</a></li>
                                <li><a style="font-size:10px;color:#009ce7;" href='@Url.Action( "CHEQUE_CASH_AdvanceReportExcel","Reports",new { WAG_Id = Model.WAG_Id,FRM_Id=Model.FRM_Id })' title="CHEQUE/CASH Advance Report"><i class="fa fa-file-excel-o m-r-5"></i>CHEQUE/CASH Advance Report.xlsx</a></li>
                            </ul>
                        </div>
                    </li>
                </ul>
                <ul style="font-size:10px;padding-left: 10px !important;">
                    <li>
                        <div class="dropdown">
                            <a href="#" style="font-size:10px;color:#009ce7;" class="action-icon dropdown-toggle" data-toggle="dropdown" aria-expanded="false"><i class="fa fa-file-excel-o m-r-5"></i>PF Reports</a>
                            <ul class="dropdown-menu pull-right">
                                @*<li><a style="font-size:10px;color:#009ce7;" href='@Url.Action( "Client_Wise_PF_Details_Excel","Reports",new { WAG_Id = Model.WAG_Id })' title="Client wise PF Details Report"><i class="fa fa-file-excel-o m-r-5"></i>Client Wise PF Details.xlsx</a></li>
                                <li><a style="font-size:10px;color:#009ce7;" href='@Url.Action( "Employees_Pending_For_Registration_Excel","Reports",new { WAG_Id = Model.WAG_Id })' title="Employees Pending For Registration Report"><i class="fa fa-file-excel-o m-r-5"></i>Employees Pending For Registration Report.xlsx</a></li>*@                               
                                @*<li><a class="reports-selection" onclick="onClientSelectionClick(@Model.WAG_Id,@Model.FRM_Id)" title="Employees PF Report"><i class="fa fa-file-excel-o m-r-5"></i>Employees PF Report.xlsx</a></li>*@

                                <li><a style="font-size:10px;color:#009ce7;" href='@Url.Action( "ClientsSelectionForWage","Reports",new { WAG_Id = Model.WAG_Id ,Model.FRM_Id})' title="Employees PF Report"><i class="fa fa-file-excel-o m-r-5"></i>Employees PF Report.xlsx</a></li>
                            </ul>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

