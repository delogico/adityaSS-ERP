@model IEnumerable<RMERP.DAL.ViewModel.WageProcessVM>
@using System.Globalization;
@*
    For more information on enabling MVC for empty projects, visit http://go.microsoft.com/fwlink/?LinkID=397860
*@
<div class="row">
    <div class="col-md-12">
        <div>
            @if (Model.Count() > 0)
            {
                <table class="table table-striped custom-table m-b-0">
                    <thead>
                        <tr>
                            <th>Wag Month</th>
                            <th>Attendance</th>
                            <th>Wage Register</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                        <tr>
                            <td><b>@item.WAG_Month.ToString("MMMM", CultureInfo.CreateSpecificCulture("IN")) - @item.WAG_Month.Year.ToString()</b></td>
                            <td>
                                @Html.ActionLink("Attendance", "WageAttendanceList", "Attendance", new { WAG_Id = item.WAG_Id })
                                [ <a data-toggle="tooltip" data-placement="top" title="Total Clients">@item.ActiveClients,</a>
                                  <a data-toggle="tooltip" data-placement="bottom" title="Imported Clients">@item.ImportedClients(),</a>
                                  <a data-toggle="tooltip" data-placement="right" title="Not Imported Clients">@item.NotImportedClients()</a>
                                ]
                            </td>
                            <td>
                                @Html.ActionLink("Wage Register", "WageRegister", "WageRegister", new { WAG_Id = item.WAG_Id })
                                [     <a data-toggle="tooltip" data-placement="top" title="Total WageRegisters">@item.ActiveClients,</a>
                                      <a data-toggle="tooltip" data-placement="bottom" title="Saved WageRegisters">@item.WageRegisterSaved(),</a>
                                      <a data-toggle="tooltip" data-placement="right" title="Not Saved WageRegisters">@item.WageRegisterNotSaved()</a>
                                ]
                            </td>
                        </tr>
                        }

                    </tbody>
                </table>
            }
            else
            {
                <p>No Wage Process To Display</p>
            }
        </div>
    </div>
</div>