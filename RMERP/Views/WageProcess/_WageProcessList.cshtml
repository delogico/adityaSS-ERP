@model IEnumerable<RMERP.DAL.ViewModel.WageProcessVM>
@using System.Globalization;
@*
    For more information on enabling MVC for empty projects, visit http://go.microsoft.com/fwlink/?LinkID=397860
*@
<div class="row">
    <div class="col-md-12">
        <div>
            @if (Model.Count() > 0)
            {
                <table class="table table-striped custom-table m-b-0">
                    <thead>
                        <tr>
                            <th>Wag Month</th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>

                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var style = (item.WageStatus == true ? "#55ce634f;" : "none");
                        <tr style="background-color:@style;">
                            <td><b>@item.WAG_Month.ToString("MMMM", CultureInfo.CreateSpecificCulture("IN")) - @item.WAG_Month.Year.ToString()</b></td>
                            <td>
                                @Html.ActionLink("Attendance", "WageAttendanceList", "Attendance", new { WAG_Id = item.WAG_Id })
                                [ <a data-toggle="tooltip" data-placement="top" title="Total Clients" style="color:black;font-weight: 400;">@item.ActiveClients,</a>
                                <a data-toggle="tooltip" data-placement="bottom" title="Imported Clients" style="color:green;font-weight: 400;">@item.ImportedClients(),</a>
                                <a data-toggle="tooltip" data-placement="right" title="Not Imported Clients" style="color:red;font-weight: 400;">@item.NotImportedClients()</a>
                                ]
                            </td>

                            <td>
                                @Html.ActionLink("Taken anount of for this month", "AdvanceRptForBank", "Employees", new { WAG_Month = item.WAG_Month })
                                [
                                <a data-toggle="tooltip" data-placement="top" title="Total employees who take advance" style="color:black;font-weight: 400;">@item.totEmpTakeAdvance</a>
                                ]
                            </td>

                            <td>
                                @*@Html.ActionLink("Update advance EMI for this month", "NotCompletedAdvanceLst", "Employees", new { WAG_Month = item.WAG_Month, WAG_Id = item.WAG_Id })*@
                                @Html.ActionLink("Update advance EMI for this month", "UpdateAdvanceEMI", "Employees", new { WAG_Month = item.WAG_Month, WAG_Id = item.WAG_Id })
                                
                            </td>

                            <td>
                                @Html.ActionLink("Wage Register", "WageRegister", "WageRegister", new { WAG_Id = item.WAG_Id })
                                [
                                <a data-toggle="tooltip" data-placement="top" title="Total WageRegisters" style="color:black;font-weight: 400;">@item.ActiveClients,</a>
                                <a data-toggle="tooltip" data-placement="bottom" title="Saved WageRegisters" style="color:green;font-weight: 400;">@item.WageRegisterSaved(),</a>
                                <a data-toggle="tooltip" data-placement="right" title="Not Saved WageRegisters" style="color:red;font-weight: 400;">@item.WageRegisterNotSaved()</a>
                                ]
                                @if (item.WageRegisterSaved() == item.ActiveClients && item.WageRegisterNotSaved() == 0)
                                {
                                    if (item.WageStatus == true)
                                    {
                                        <span class='label label-danger-border'> Wage register confirmed. </span>
                                    }
                                    else
                                    {
                                        <a class="btn btn-primary  btn-sm" onclick="return window.confirm('Are you sure,You want to confirm? Now onwards wage register can not be able to modify.')"
                                           href='@Url.Action("WageRegisterStatus", "WageProcess", new { WAG_Id = item.WAG_Id})' title="Confirm">
                                            Confirm WageRegisters
                                        </a>
                                    }
                                }
                            </td>

                        </tr>
                        }

                    </tbody>
                </table>
            }
            else
            {
                <p>No Wage Process To Display</p>
            }
        </div>
    </div>
</div>