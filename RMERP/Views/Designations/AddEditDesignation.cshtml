@model RMERP.DAL.ViewModel.DesignationVM
@{
    ViewData["Title"] = "Designation";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}
@section Breadcrumbs{
    <li class="breadcrumb-item">@Html.ActionLink("Designations", "Index", "Designations")</li>
    <li class="breadcrumb-item">Add-Edit Designation</li>
}
@section scripts{

    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {
            alert('@TempData["message"]');
        });
        </script>
    };
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>
}

<div class="modal-dialog">
    <div class="modal-content modal-md">
        <div class="modal-header">
            <h4 class="modal-title"> @ViewData["Title"]</h4>
        </div>
        <div class="modal-body">
            @using (Html.BeginForm("AddEditDesignation", "Designations", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="form-group">
                    @Html.HiddenFor(m => m.DES_Id)
                    @Html.LabelFor(m => m.DES_Title)
                    @Html.TextBoxFor(m => m.DES_Title, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.DES_Title, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.CheckBoxFor(m => m.DES_Exclude_LWF)
                    @Html.LabelFor(m => m.DES_Exclude_LWF)
                    @Html.ValidationMessageFor(model => model.DES_Exclude_LWF, "", new { @class = "text-danger" })
                </div>
                <div class="m-t-20 text-center">
                    <input type="submit" name="Submit Designation" id="btnSubmit" class="btn btn-primary" />
                </div>
            }
        </div>
    </div>
</div>
