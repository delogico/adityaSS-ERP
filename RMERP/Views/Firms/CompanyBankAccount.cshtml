@model List<RMERP.DAL.ViewModel.CompanyBankAccountVM>
@{
    ViewData["Title"] = "Bank Accounts";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
    int FRM_Id = ViewBag.FRM_Id;
}
@section Breadcrumbs {
    <li class="breadcrumb-item">@Html.ActionLink("Firms", "Index", "Firms")</li>
    <li class="breadcrumb-item">@ViewBag.FRM_Name's Bank Account</li>
}
@section scripts {
    @if (TempData["message"] != null)
    {
        <script>
                $(document).ready(function () {
                alert('@TempData["message"]');
            });
        </script>
    } ;
}
<style>
    .modal-dialog {
        transform: translate(0, -50%);
        top: 30%;
        margin: 0 auto;
    }
</style>
<div>
    <div class="content container-fluid">
        <div class="row">
            <div class="col-sm-8">
                <h4 class="page-title">@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-4 text-right m-b-30">
                <a class="btn btn-primary rounded" href="@Url.Action("AddEditCompanyBankAccount", "Firms", new { FRM_Id = FRM_Id })"><i class="fa fa-plus"></i> Register New Bank</a>
            </div>
        </div>
        <div class="row">
            <div class="col-md-8">
                <div class="table-responsive">
                    <table class="table table-striped custom-table m-b-0">
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><b>@item.CBA_Bank</b></td>
                                    <td>@item.CBA_Account_Number</td>
                                    <td>@item.CBA_Bank_IFSC</td>
                                    <td> <a href='@Url.Action("AddEditCompanyBankAccount", "Firms", new { CBA_Id = item.CBA_Id })' title="Edit"><i class="fa fa-pencil m-r-5"></i> Edit</a> </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

