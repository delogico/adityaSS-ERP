@model IEnumerable<RMERP.DAL.Models.Firms>
@{
    ViewData["Title"] = "Our Firms";
    //ViewBag["Modeltitle"] = Model.Firms.FrmId > 0 ? "Edit Firm" : "Add Firm";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}


@section scripts{
    @if (TempData["message"] != null)
    {
        <script>
            $(document).ready(function () {
            alert('@TempData["message"]');
        });
        </script>
    };

}<style>
    .modal-dialog {
        transform: translate(0, -50%);
        top: 30%;
        margin: 0 auto;
    }
    </style>
<div>
    <div class="content container-fluid">
        <div class="row">
            <div class="col-sm-8">
                <h4 class="page-title">@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-4 text-right m-b-30">
                <a class="btn btn-primary rounded" href="@Url.Action("AddEditFirms","Firms")"><i class="fa fa-plus"></i> Add New Firm</a>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div>
                    <table class="table table-striped custom-table m-b-0">
                       
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><b>@item.FrmName</b></td>
                                    <td class="text-right">
                                        <div class="dropdown">
                                            <a href="#" class="action-icon dropdown-toggle" data-toggle="dropdown" aria-expanded="false"><i class="fa fa-ellipsis-v"></i></a>
                                            <ul class="dropdown-menu pull-right">
                                                <li><a href='@Url.Action("AddEditFirms","Firms",new { id=item.FrmId})' title="Edit"><i class="fa fa-pencil m-r-5"></i> Edit</a></li>
                                                <li><a href='@Url.Action("DeleteFirms","Firms",new { id=item.FrmId})' title="Delete" onclick="return confirm('Are you sure?');"><i class="fa fa-trash m-r-5"></i> Delete</a></li>                                                
                                            </ul>
                                    </div>
                                </td>
                            </tr>
                        }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

