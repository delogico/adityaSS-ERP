@model RMERP.DAL.ViewModel.CompanyBankAccountVM
@{
    ViewData["Title"] = "Register Bank Account";
    Layout = "~/Views/Shared/_RMLayout.cshtml";
}
@section Breadcrumbs {
    <li class="breadcrumb-item">@Html.ActionLink("Firms", "Index", "Firms")</li>
    <li class="breadcrumb-item">Register Bank Account</li>
}
@section scripts {
    <script src="@Url.Content("~/assets/lib/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/assets/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>
    @if (TempData["message"] != null)
    {
        <script>
                $(document).ready(function () {
                alert('@TempData["message"]');
            });
        </script>
        <script>
            $('.selectpicker').selectpicker({
                liveSearch: true,
                showSubtext: true
            });
        </script>
    }
    ;
}

<div class="modal-dialog">
    <div class="modal-content modal-md">
        <div class="modal-body">
            <p class="div-title">@ViewData["Title"]</p>
            <br />
            @using (Html.BeginForm("AddEditCompanyBankAccount", "Firms", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                <div class="form-group">
                    @Html.HiddenFor(m => m.FRM_Id)
                    @Html.HiddenFor(m => m.CBA_Id)

                    @Html.LabelFor(m => m.CBA_Bank)
                    @Html.DropDownListFor(m => m.CBA_Bank, (IEnumerable<SelectListItem>)ViewBag.REGISTER_BANK, "Select Bank",  new { @class = "form-control", id = "CBA_Bank" })
                    @Html.ValidationMessageFor(model => model.CBA_Bank, "", new { @class = "text-danger" })
                </div>
                <div class="form-group">
                    @Html.LabelFor(m => m.CBA_Account_Number)
                    @Html.TextBoxFor(m => m.CBA_Account_Number, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.CBA_Account_Number, "", new { @class = "text-danger" })
                </div>
                <div class="form-group">
                    @Html.LabelFor(m => m.CBA_Bank_IFSC)
                    @Html.TextBoxFor(m => m.CBA_Bank_IFSC, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.CBA_Bank_IFSC, "", new { @class = "text-danger" })
                </div>
            <div class="m-t-20 text-center">
                <input type="submit" name="Submit Firm" id="btnSubmit" class="btn btn-primary" />
            </div>
                        }
        </div>
    </div>
</div>
